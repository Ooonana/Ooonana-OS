# i3 config file (v4)
set $mod Mod4
font pango:monospace 10

floating_modifier $mod
focus_follows_mouse yes
mouse_warping none
workspace_layout default
hide_edge_borders smart
default_border pixel 2
default_floating_border pixel 2
for_window [class=".*"] border pixel 2
for_window [class="Yad"] floating enable
for_window [class="Pavucontrol"] floating enable
for_window [class="Blueman-manager"] floating enable
for_window [window_role="pop-up"] floating enable

exec_always --no-startup-id ooonana-theme-env apply
exec --no-startup-id xsetroot -name "Ooonana OS"
exec --no-startup-id sh -c 'command -v picom >/dev/null 2>&1 && picom --config /etc/ooonana/picom.conf &'
exec --no-startup-id sh -c 'command -v dunst >/dev/null 2>&1 && dunst -config /etc/ooonana/dunstrc &'
exec --no-startup-id sh -c 'command -v xsettingsd >/dev/null 2>&1 && xsettingsd -c /etc/ooonana/xsettingsd.conf &'
exec_always --no-startup-id sh -c 'command -v polybar >/dev/null 2>&1 && killall polybar >/dev/null 2>&1 || true; command -v polybar >/dev/null 2>&1 && polybar -c /etc/ooonana/polybar.ini ooonana &'
exec --no-startup-id sh -c 'command -v nm-applet >/dev/null 2>&1 && [ -S /run/dbus/system_bus_socket ] && nm-applet --indicator &'
exec --no-startup-id sh -c 'command -v blueman-applet >/dev/null 2>&1 && [ -S /run/dbus/system_bus_socket ] && blueman-applet &'

bindsym $mod+Return exec ooonana-theme-env xterm
bindsym $mod+d exec sh -c 'command -v rofi >/dev/null 2>&1 && rofi -show drun -theme /etc/ooonana/rofi.rasi || dmenu_run'
bindsym $mod+Shift+f exec ooonana-files
bindsym $mod+Shift+w exec ooonana-browser
bindsym $mod+n exec ooonana-wifi
bindsym $mod+b exec ooonana-bluetooth
bindsym $mod+Shift+n exec ooonana-rofi-wifi
bindsym $mod+Shift+b exec ooonana-rofi-bluetooth
bindsym $mod+Shift+s exec ooonana-settings-launch
bindsym $mod+Shift+a exec ooonana-ai-launch
bindsym $mod+Shift+o exec ooonana-packages-app
bindsym $mod+Shift+i exec ooonana-gui-installer
bindsym $mod+Shift+p exec ooonana-wallpaper
bindsym $mod+Shift+t exec ooonana-theme-env toggle
bindsym Print exec ooonana-screenshot
bindsym $mod+Shift+g exec ooonana-editor
bindsym $mod+Shift+m exec ooonana-music
bindsym $mod+Shift+x exec ooonana-processes
bindsym $mod+Shift+u exec ooonana-ranger
bindsym XF86TouchpadToggle exec ooonana-touchpad toggle
bindsym XF86TouchpadOn exec ooonana-touchpad on
bindsym XF86TouchpadOff exec ooonana-touchpad off
bindsym $mod+Shift+r restart
bindsym $mod+Shift+q kill
bindsym $mod+Shift+e exec "i3-nagbar -t warning -m 'Exit Ooonana i3?' -b 'Exit' 'i3-msg exit'"

bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

bindsym $mod+f fullscreen toggle
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

