#!/usr/bin/env bash
set -euo pipefail

TARGET=""
SOURCE="/"
MOUNT_POINT="/run/ooonana-target"
YES=0
DRY_RUN=0
HOSTNAME_VALUE=""
USER_NAME=""
THEME=""
PASSWORD_STDIN=0
PASSWORD_VALUE=""
KERNEL_PATH=""
BOOTLOADER="auto"
SMOKE=0
GUI_SMOKE=0
LOOP_DEV=""
TARGET_PART=""
INSTALL_DEVICE=""
TARGET_MODE=""

usage() {
  cat <<'USAGE'
Install Ooonana OS to a writable disk.

Usage:
  ooonana-install --target PATH --yes [options]

Options:
  --target PATH       Target disk or ext4 image
  --source PATH       Source root (default: /)
  --mount-point PATH  Temporary mount point (default: /run/ooonana-target)
  --hostname NAME     Write installed hostname
  --user NAME         Create installed user
  --theme dark|light  Write installed UI theme
  --password-stdin    Read password for --user from stdin
  --kernel PATH       Kernel to install as /boot/vmlinuz
  --bootloader auto|grub|none
  --smoke             Add smoke boot argument
  --gui-smoke         Add GUI smoke boot argument
  --yes               Confirm destructive install
  --dry-run           Print commands only
  -h, --help          Show help
USAGE
}

die() {
  printf 'ooonana-install: %s\n' "$*" >&2
  exit 1
}

print_cmd() {
  local arg
  for arg in "$@"; do
    printf '%q ' "$arg"
  done
  printf '\n'
}

run_cmd() {
  if [[ "$DRY_RUN" -eq 1 ]]; then
    print_cmd "$@"
  else
    "$@"
  fi
}

require_commands() {
  local cmd
  [[ "$DRY_RUN" -eq 0 ]] || return 0
  for cmd in "$@"; do
    command -v "$cmd" >/dev/null 2>&1 || die "missing command: $cmd"
  done
}

partition_path() {
  case "$1" in
    /dev/nvme*n[0-9]|/dev/mmcblk[0-9]*|/dev/loop[0-9]*) printf '%sp1\n' "$1" ;;
    *) printf '%s1\n' "$1" ;;
  esac
}

wait_for_block() {
  local path="$1"
  local i
  for i in $(seq 1 50); do
    [[ -b "$path" ]] && return 0
    sleep 0.1
  done
  return 1
}

looks_like_partition() {
  case "$1" in
    /dev/nvme*n*p[0-9]*|/dev/mmcblk*p[0-9]*|/dev/loop*p[0-9]*|/dev/*[0-9]) return 0 ;;
    *) return 1 ;;
  esac
}

detect_target_mode() {
  if [[ "$BOOTLOADER" == "none" ]]; then
    printf 'partition\n'
    return 0
  fi
  if [[ "$DRY_RUN" -eq 1 ]]; then
    case "$TARGET" in
      /dev/*)
        if looks_like_partition "$TARGET"; then
          printf 'partition\n'
        else
          printf 'disk\n'
        fi
        ;;
      *) printf 'disk\n' ;;
    esac
    return 0
  fi
  if [[ -f "$TARGET" ]]; then
    printf 'disk\n'
    return 0
  fi
  if [[ -b "$TARGET" ]]; then
    if command -v lsblk >/dev/null 2>&1; then
      case "$(lsblk -dn -o TYPE "$TARGET" 2>/dev/null || true)" in
        disk|loop) printf 'disk\n'; return 0 ;;
        part) printf 'partition\n'; return 0 ;;
      esac
    fi
    if looks_like_partition "$TARGET"; then
      printf 'partition\n'
    else
      printf 'disk\n'
    fi
    return 0
  fi
  die "target must be block device or existing raw file: $TARGET"
}

kernel_append() {
  local append="root=/dev/vda1 rw console=tty0 console=ttyS0 panic=1 init=/sbin/init ooonana.edition=full-i3"
  if [[ "$SMOKE" -eq 1 ]]; then
    append="$append ooonana.smoke=1"
  fi
  if [[ "$GUI_SMOKE" -eq 1 ]]; then
    append="$append ooonana.gui-smoke=1"
  fi
  printf '%s\n' "$append"
}

write_grub_config() {
  local root="$1"
  local append
  append="$(kernel_append)"
  mkdir -p "$root/boot/grub"
  cat > "$root/boot/grub/grub.cfg" <<EOF
serial --unit=0 --speed=115200
terminal_input serial
terminal_output serial
set timeout=1
set default=0

menuentry 'Ooonana OS Full i3' {
  linux /boot/vmlinuz $append
}
EOF
}

install_kernel() {
  local root="$1"
  run_cmd mkdir -p "$root/boot"
  if [[ -n "$KERNEL_PATH" ]]; then
    run_cmd install -m 0644 "$KERNEL_PATH" "$root/boot/vmlinuz"
    return 0
  fi
  if [[ "$DRY_RUN" -eq 1 ]]; then
    printf 'use existing %s/boot/vmlinuz\n' "$root"
    return 0
  fi
  [[ -f "$root/boot/vmlinuz" ]] || die "missing /boot/vmlinuz; pass --kernel PATH"
}

valid_user() {
  [[ "$1" =~ ^[A-Za-z_][A-Za-z0-9_-]*$ ]]
}

valid_hostname() {
  [[ "$1" =~ ^[A-Za-z0-9][A-Za-z0-9-]*$ ]]
}

next_uid() {
  local passwd_file="$1"
  if [[ -f "$passwd_file" ]]; then
    awk -F: 'BEGIN { uid = 999 } $3 >= 1000 && $3 < 60000 && $3 > uid { uid = $3 } END { print uid + 1 }' "$passwd_file"
  else
    printf '1000\n'
  fi
}

create_user() {
  local root="$1"
  local passwd_file="$root/etc/passwd"
  local group_file="$root/etc/group"
  local home_dir="$root/home/$USER_NAME"
  local uid

  [[ -n "$USER_NAME" ]] || return 0
  valid_user "$USER_NAME" || die "bad user name: $USER_NAME"

  mkdir -p "$(dirname "$passwd_file")" "$(dirname "$group_file")" "$home_dir"
  [[ -f "$passwd_file" ]] || printf 'root:x:0:0:root:/root:/bin/sh\n' > "$passwd_file"
  [[ -f "$group_file" ]] || printf 'root:x:0:\n' > "$group_file"
  if grep -q "^$USER_NAME:" "$passwd_file"; then
    printf 'user exists: %s\n' "$USER_NAME"
    return 0
  fi

  uid="$(next_uid "$passwd_file")"
  printf '%s:x:%s:%s:Ooonana User:/home/%s:/bin/sh\n' "$USER_NAME" "$uid" "$uid" "$USER_NAME" >> "$passwd_file"
  printf '%s:x:%s:\n' "$USER_NAME" "$uid" >> "$group_file"
  chmod 755 "$home_dir" 2>/dev/null || true
  printf 'user created: %s\n' "$USER_NAME"
}

hash_password() {
  local password="$1"
  if command -v openssl >/dev/null 2>&1; then
    printf '%s\n' "$password" | openssl passwd -6 -stdin
    return 0
  fi
  if command -v python3 >/dev/null 2>&1; then
    printf '%s\n' "$password" | python3 -c 'import crypt, sys; pw = sys.stdin.readline().rstrip("\n"); print(crypt.crypt(pw, crypt.mksalt(crypt.METHOD_SHA512)))'
    return 0
  fi
  return 1
}

write_password() {
  local root="$1"
  local shadow_file="$root/etc/shadow"
  local tmp_file
  local hash
  local day

  [[ "$PASSWORD_STDIN" -eq 1 ]] || return 0
  [[ -n "$USER_NAME" ]] || die "--password-stdin requires --user NAME"
  [[ -n "$PASSWORD_VALUE" ]] || return 0

  hash="$(hash_password "$PASSWORD_VALUE")" || die "password hashing requires openssl or python3 crypt"
  day="$(($(date +%s) / 86400))"
  mkdir -p "$(dirname "$shadow_file")"
  [[ -f "$shadow_file" ]] || printf 'root:*:%s:0:99999:7:::\n' "$day" > "$shadow_file"
  tmp_file="$shadow_file.tmp.$$"
  if grep -q "^$USER_NAME:" "$shadow_file"; then
    awk -F: -v user="$USER_NAME" -v hash="$hash" -v day="$day" 'BEGIN { OFS = FS } $1 == user { $2 = hash; $3 = day } { print }' "$shadow_file" > "$tmp_file"
  else
    cat "$shadow_file" > "$tmp_file"
    printf '%s:%s:%s:0:99999:7:::\n' "$USER_NAME" "$hash" "$day" >> "$tmp_file"
  fi
  mv "$tmp_file" "$shadow_file"
  chmod 600 "$shadow_file" 2>/dev/null || true
  printf 'password set: %s\n' "$USER_NAME"
}

write_hostname() {
  local root="$1"
  [[ -n "$HOSTNAME_VALUE" ]] || return 0
  valid_hostname "$HOSTNAME_VALUE" || die "bad hostname: $HOSTNAME_VALUE"
  printf '%s\n' "$HOSTNAME_VALUE" > "$root/etc/hostname"
  cat > "$root/etc/hosts" <<EOF
127.0.0.1 localhost $HOSTNAME_VALUE
::1 localhost ip6-localhost ip6-loopback
EOF
  printf 'hostname: %s\n' "$HOSTNAME_VALUE"
}

write_theme() {
  local root="$1"
  [[ -n "$THEME" ]] || return 0
  case "$THEME" in
    dark|light) ;;
    *) die "theme must be dark or light" ;;
  esac
  mkdir -p "$root/etc/ooonana"
  printf '%s\n' "$THEME" > "$root/etc/ooonana/theme"
  cat > "$root/etc/ooonana/theme.conf" <<EOF
OOONANA_THEME="$THEME"
EOF
  printf 'theme: %s\n' "$THEME"
}

apply_install_config() {
  local root="$1"
  create_user "$root"
  write_password "$root"
  write_hostname "$root"
  write_theme "$root"
}

prepare_target() {
  TARGET_MODE="$(detect_target_mode)"
  case "$TARGET_MODE" in
    disk)
      require_commands parted mkfs.ext4 mount rsync grub-install install
      if [[ "$DRY_RUN" -eq 1 ]]; then
        run_cmd parted -s "$TARGET" mklabel msdos mkpart primary ext4 1MiB 100% set 1 boot on
        run_cmd losetup --find --show --partscan "$TARGET"
        INSTALL_DEVICE="LOOP_DEVICE"
        TARGET_PART="LOOP_PARTITION"
      else
        parted -s "$TARGET" mklabel msdos mkpart primary ext4 1MiB 100% set 1 boot on
        if [[ -f "$TARGET" ]]; then
          require_commands losetup
          LOOP_DEV="$(losetup --find --show --partscan "$TARGET")"
          partprobe "$LOOP_DEV" 2>/dev/null || true
          INSTALL_DEVICE="$LOOP_DEV"
          TARGET_PART="$(partition_path "$LOOP_DEV")"
        else
          INSTALL_DEVICE="$TARGET"
          partprobe "$TARGET" 2>/dev/null || true
          TARGET_PART="$(partition_path "$TARGET")"
        fi
        wait_for_block "$TARGET_PART" || die "missing target partition: $TARGET_PART"
      fi
      ;;
    partition)
      require_commands mkfs.ext4 mount rsync
      INSTALL_DEVICE=""
      TARGET_PART="$TARGET"
      if [[ "$BOOTLOADER" == "grub" ]]; then
        die "--bootloader grub requires whole disk target"
      fi
      ;;
    *) die "unknown target mode: $TARGET_MODE" ;;
  esac

  run_cmd mkfs.ext4 -F -L OOONANA_ROOT "$TARGET_PART"
  run_cmd mkdir -p "$MOUNT_POINT"
  run_cmd mount "$TARGET_PART" "$MOUNT_POINT"
}

install_bootloader() {
  local append
  case "$BOOTLOADER" in
    none) return 0 ;;
    auto)
      [[ "$TARGET_MODE" == "disk" ]] || return 0
      ;;
    grub)
      [[ "$TARGET_MODE" == "disk" ]] || die "--bootloader grub requires whole disk target"
      ;;
    *) die "bootloader must be auto, grub, or none" ;;
  esac

  install_kernel "$MOUNT_POINT"
  if [[ "$DRY_RUN" -eq 1 ]]; then
    append="$(kernel_append)"
    printf 'grub.cfg: linux /boot/vmlinuz %s\n' "$append"
  else
    write_grub_config "$MOUNT_POINT"
  fi
  run_cmd grub-install --target=i386-pc --boot-directory="$MOUNT_POINT/boot" --modules="part_msdos ext2" --no-floppy "$INSTALL_DEVICE"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --target) TARGET="$2"; shift 2 ;;
    --source) SOURCE="$2"; shift 2 ;;
    --mount-point) MOUNT_POINT="$2"; shift 2 ;;
    --hostname) HOSTNAME_VALUE="$2"; shift 2 ;;
    --user) USER_NAME="$2"; shift 2 ;;
    --theme) THEME="$2"; shift 2 ;;
    --password-stdin) PASSWORD_STDIN=1; shift ;;
    --kernel) KERNEL_PATH="$2"; shift 2 ;;
    --bootloader) BOOTLOADER="$2"; shift 2 ;;
    --smoke) SMOKE=1; shift ;;
    --gui-smoke) GUI_SMOKE=1; shift ;;
    --yes) YES=1; shift ;;
    --dry-run) DRY_RUN=1; shift ;;
    -h|--help) usage; exit 0 ;;
    *) die "unknown option: $1" ;;
  esac
done

[[ -n "$TARGET" ]] || die "--target required"
[[ "$YES" -eq 1 ]] || die "--yes required because install formats target"
case "$BOOTLOADER" in
  auto|grub|none) ;;
  *) die "bootloader must be auto, grub, or none" ;;
esac
if [[ "$PASSWORD_STDIN" -eq 1 && "$DRY_RUN" -eq 0 ]]; then
  IFS= read -r PASSWORD_VALUE || true
fi

if [[ "$DRY_RUN" -eq 0 ]]; then
  [[ "${EUID:-$(id -u)}" -eq 0 ]] || die "run as root"
  [[ -e "$TARGET" ]] || die "target missing: $TARGET"
  [[ -d "$SOURCE" ]] || die "source missing: $SOURCE"
  [[ -z "$KERNEL_PATH" || -f "$KERNEL_PATH" ]] || die "kernel missing: $KERNEL_PATH"
fi

cleanup() {
  if [[ "$DRY_RUN" -eq 0 ]] && mountpoint -q "$MOUNT_POINT"; then
    umount "$MOUNT_POINT"
  fi
  if [[ "$DRY_RUN" -eq 0 && -n "$LOOP_DEV" ]]; then
    losetup -d "$LOOP_DEV" 2>/dev/null || true
  fi
}
trap cleanup EXIT

prepare_target
run_cmd rsync -aHAX --numeric-ids \
  --exclude '/dev/*' \
  --exclude '/proc/*' \
  --exclude '/sys/*' \
  --exclude '/run/*' \
  --exclude '/tmp/*' \
  --exclude '/mnt/*' \
  --exclude '/media/*' \
  --exclude '/lost+found' \
  "$SOURCE"/ "$MOUNT_POINT"/

if [[ "$DRY_RUN" -eq 1 ]]; then
  [[ -z "$USER_NAME" ]] || printf 'create user %s\n' "$USER_NAME"
  [[ -z "$HOSTNAME_VALUE" ]] || printf 'write hostname %s\n' "$HOSTNAME_VALUE"
  [[ -z "$THEME" ]] || printf 'write theme %s\n' "$THEME"
  [[ "$PASSWORD_STDIN" -eq 0 ]] || printf 'read password from stdin\n'
  install_bootloader
  print_cmd mkdir -p "$MOUNT_POINT/var/lib/ooonana"
  print_cmd sh -c "printf 'installed\n' > '$MOUNT_POINT/var/lib/ooonana/install-ok'"
  print_cmd sh -c "printf 'LABEL=OOONANA_ROOT / ext4 defaults 0 1\nproc /proc proc defaults 0 0\n' > '$MOUNT_POINT/etc/fstab'"
  print_cmd umount "$MOUNT_POINT"
else
  apply_install_config "$MOUNT_POINT"
  install_bootloader
  mkdir -p "$MOUNT_POINT/var/lib/ooonana"
  printf 'installed\n' > "$MOUNT_POINT/var/lib/ooonana/install-ok"
  cat > "$MOUNT_POINT/etc/fstab" <<'EOF'
LABEL=OOONANA_ROOT / ext4 defaults 0 1
proc /proc proc defaults 0 0
EOF
  umount "$MOUNT_POINT"
fi

printf 'OOONANA_INSTALL_OK\n'
