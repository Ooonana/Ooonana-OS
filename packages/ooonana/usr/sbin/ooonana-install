#!/usr/bin/env bash
set -euo pipefail

TARGET=""
SOURCE="/"
MOUNT_POINT="/run/ooonana-target"
YES=0
DRY_RUN=0
HOSTNAME_VALUE=""
USER_NAME=""
THEME=""
CLOUD_REPO=""
PASSWORD_STDIN=0
PASSWORD_VALUE=""
KERNEL_PATH=""
BOOTLOADER="auto"
SMOKE=0
GUI_SMOKE=0
LOOP_DEV=""
TARGET_PART=""
INSTALL_DEVICE=""
TARGET_MODE=""
TARGET_PARTUUID=""
HOME_PART=""
SWAP_PART=""
EFI_PART=""
FORMAT_ROOT=1
FORMAT_HOME=1
FORMAT_SWAP=1
FORMAT_EFI=0

usage() {
  cat <<'USAGE'
Install Ooonana OS to a writable disk.

Usage:
  ooonana-install --target PATH --yes [options]

Options:
  --target PATH       Target disk or ext4 image
  --source PATH       Source root (default: /)
  --mount-point PATH  Temporary mount point (default: /run/ooonana-target)
  --hostname NAME     Write installed hostname
  --user NAME         Create installed user
  --theme dark|light  Write installed UI theme
  --cloud-repo URI    Write Ooonana cloud package repo
  --password-stdin    Read password for --user from stdin
  --kernel PATH       Kernel to install as /boot/vmlinuz
  --bootloader auto|grub|none
  --home-part PATH    Optional /home partition
  --swap-part PATH    Optional swap partition
  --efi-part PATH     Optional /boot/efi partition
  --keep-root         Do not format root partition in partition mode
  --keep-home         Do not format /home partition
  --keep-swap         Do not initialize swap partition
  --keep-efi          Do not format EFI partition (default)
  --format-efi        Format EFI partition as FAT32 with label OOONANA_EFI
  --smoke             Add smoke boot argument
  --gui-smoke         Add GUI smoke boot argument
  --yes               Confirm destructive install
  --dry-run           Print commands only
  -h, --help          Show help
USAGE
}

die() {
  printf 'ooonana-install: %s\n' "$*" >&2
  exit 1
}

print_cmd() {
  local arg
  for arg in "$@"; do
    printf '%q ' "$arg"
  done
  printf '\n'
}

run_cmd() {
  if [[ "$DRY_RUN" -eq 1 ]]; then
    print_cmd "$@"
  else
    "$@"
  fi
}

require_commands() {
  local cmd
  [[ "$DRY_RUN" -eq 0 ]] || return 0
  for cmd in "$@"; do
    command -v "$cmd" >/dev/null 2>&1 || die "missing command: $cmd"
  done
}

partition_path() {
  case "$1" in
    /dev/nvme*n[0-9]|/dev/mmcblk[0-9]*|/dev/loop[0-9]*) printf '%sp1\n' "$1" ;;
    *) printf '%s1\n' "$1" ;;
  esac
}

wait_for_block() {
  local path="$1"
  local i
  for i in $(seq 1 50); do
    [[ -b "$path" ]] && return 0
    sleep 0.1
  done
  return 1
}

looks_like_partition() {
  case "$1" in
    /dev/nvme*n*p[0-9]*|/dev/mmcblk*p[0-9]*|/dev/loop*p[0-9]*|/dev/*[0-9]) return 0 ;;
    *) return 1 ;;
  esac
}

detect_target_mode() {
  if [[ "$BOOTLOADER" == "none" ]]; then
    printf 'partition\n'
    return 0
  fi
  if [[ "$DRY_RUN" -eq 1 ]]; then
    case "$TARGET" in
      /dev/*)
        if looks_like_partition "$TARGET"; then
          printf 'partition\n'
        else
          printf 'disk\n'
        fi
        ;;
      *) printf 'disk\n' ;;
    esac
    return 0
  fi
  if [[ -f "$TARGET" ]]; then
    printf 'disk\n'
    return 0
  fi
  if [[ -b "$TARGET" ]]; then
    if command -v lsblk >/dev/null 2>&1; then
      case "$(lsblk -dn -o TYPE "$TARGET" 2>/dev/null || true)" in
        disk|loop) printf 'disk\n'; return 0 ;;
        part) printf 'partition\n'; return 0 ;;
      esac
    fi
    if looks_like_partition "$TARGET"; then
      printf 'partition\n'
    else
      printf 'disk\n'
    fi
    return 0
  fi
  die "target must be block device or existing raw file: $TARGET"
}

kernel_append() {
  local root_spec="${1:-PARTUUID=TARGET_PARTUUID}"
  local console_args="console=ttyS0 console=tty0"
  if [[ "$SMOKE" -eq 1 ]]; then
    console_args="console=tty0 console=ttyS0"
  fi
  local append="root=$root_spec rw $console_args panic=1 init=/sbin/init ooonana.edition=full-i3"
  if [[ "$SMOKE" -eq 1 ]]; then
    append="$append ooonana.smoke=1"
  fi
  if [[ "$GUI_SMOKE" -eq 1 ]]; then
    append="$append ooonana.gui-smoke=1"
  fi
  printf '%s\n' "$append"
}

write_grub_config() {
  local root="$1"
  local root_spec="$2"
  local append
  append="$(kernel_append "$root_spec")"
  mkdir -p "$root/boot/grub"
  if [[ -f "$root/usr/share/ooonana/logo.txt" ]]; then
    run_cmd install -m 0644 "$root/usr/share/ooonana/logo.txt" "$root/boot/grub/ooonana-logo.txt"
  fi
  cat > "$root/boot/grub/theme.txt" <<'EOF'
title-text: "Ooonana OS"
title-color: "#ffb21a"
desktop-color: "#050505"
terminal-font: "Unifont Regular 16"
message-color: "#ffb21a"
selected-item-color: "#050505"
selected-item-background-color: "#ffb21a"
item-color: "#ffb21a"
item-font: "Unifont Regular 16"
EOF
  cat > "$root/boot/grub/grub.cfg" <<EOF
insmod all_video
if loadfont /boot/grub/fonts/unicode.pf2; then
  insmod gfxterm
fi
serial --unit=0 --speed=115200
terminal_input console serial
terminal_output console serial
if [ -f /boot/grub/theme.txt ]; then
  set theme=/boot/grub/theme.txt
fi
if terminal_output gfxterm serial; then
  true
fi
clear
echo 'Ooonana OS'
if [ -f /boot/grub/ooonana-logo.txt ]; then
  cat /boot/grub/ooonana-logo.txt
fi
set timeout=5
set default=0

menuentry 'Ooonana OS Full i3' {
  linux /boot/vmlinuz $append
}
EOF
}

install_kernel() {
  local root="$1"
  run_cmd mkdir -p "$root/boot"
  if [[ -n "$KERNEL_PATH" ]]; then
    run_cmd install -m 0644 "$KERNEL_PATH" "$root/boot/vmlinuz"
    return 0
  fi
  if [[ "$DRY_RUN" -eq 1 ]]; then
    printf 'use existing %s/boot/vmlinuz\n' "$root"
    return 0
  fi
  [[ -f "$root/boot/vmlinuz" ]] || die "missing /boot/vmlinuz; pass --kernel PATH"
}

valid_user() {
  [[ "$1" =~ ^[A-Za-z_][A-Za-z0-9_-]*$ ]]
}

valid_hostname() {
  [[ "$1" =~ ^[A-Za-z0-9][A-Za-z0-9-]*$ ]]
}

valid_repo_uri() {
  case "$1" in
    http://*|https://*|file://*|/*) return 0 ;;
    *) return 1 ;;
  esac
}

require_block_or_dry() {
  local path="$1"
  local label="$2"
  [[ -n "$path" ]] || return 0
  [[ "$DRY_RUN" -eq 1 ]] && return 0
  [[ -b "$path" ]] || die "$label must be a block device: $path"
}

mount_extra_partitions() {
  if [[ -n "$HOME_PART" ]]; then
    require_commands mount
    [[ "$FORMAT_HOME" -eq 0 ]] || require_commands mkfs.ext4
    if [[ "$FORMAT_HOME" -eq 1 ]]; then
      run_cmd mkfs.ext4 -F -L OOONANA_HOME "$HOME_PART"
    fi
    run_cmd mkdir -p "$MOUNT_POINT/home"
    run_cmd mount "$HOME_PART" "$MOUNT_POINT/home"
  fi

  if [[ -n "$EFI_PART" ]]; then
    require_commands mount
    [[ "$FORMAT_EFI" -eq 0 ]] || require_commands mkfs.vfat
    if [[ "$FORMAT_EFI" -eq 1 ]]; then
      run_cmd mkfs.vfat -F 32 -n OOONANA_EFI "$EFI_PART"
    fi
    run_cmd mkdir -p "$MOUNT_POINT/boot/efi"
    run_cmd mount "$EFI_PART" "$MOUNT_POINT/boot/efi"
  fi

  if [[ -n "$SWAP_PART" ]]; then
    [[ "$FORMAT_SWAP" -eq 0 ]] || require_commands mkswap
    if [[ "$FORMAT_SWAP" -eq 1 ]]; then
      run_cmd mkswap -L OOONANA_SWAP "$SWAP_PART"
    fi
  fi
}

fstab_device() {
  local formatted_label="$1"
  local keep_path="$2"
  local format_flag="$3"
  if [[ "$format_flag" -eq 1 ]]; then
    printf 'LABEL=%s\n' "$formatted_label"
  else
    printf '%s\n' "$keep_path"
  fi
}

build_fstab() {
  printf 'LABEL=OOONANA_ROOT / ext4 defaults 0 1\n'
  if [[ -n "$HOME_PART" ]]; then
    printf '%s /home ext4 defaults 0 2\n' "$(fstab_device OOONANA_HOME "$HOME_PART" "$FORMAT_HOME")"
  fi
  if [[ -n "$EFI_PART" ]]; then
    printf '%s /boot/efi vfat umask=0077 0 1\n' "$(fstab_device OOONANA_EFI "$EFI_PART" "$FORMAT_EFI")"
  fi
  if [[ -n "$SWAP_PART" ]]; then
    printf '%s none swap sw 0 0\n' "$(fstab_device OOONANA_SWAP "$SWAP_PART" "$FORMAT_SWAP")"
  fi
  printf 'proc /proc proc defaults 0 0\n'
}

write_fstab() {
  local root="$1"
  if [[ "$DRY_RUN" -eq 1 ]]; then
    printf 'fstab:\n'
    build_fstab
  else
    build_fstab > "$root/etc/fstab"
  fi
}

unmount_targets() {
  if [[ -n "$EFI_PART" ]]; then
    run_cmd umount "$MOUNT_POINT/boot/efi"
  fi
  if [[ -n "$HOME_PART" ]]; then
    run_cmd umount "$MOUNT_POINT/home"
  fi
  run_cmd umount "$MOUNT_POINT"
}

next_uid() {
  local passwd_file="$1"
  if [[ -f "$passwd_file" ]]; then
    awk -F: 'BEGIN { uid = 999 } $3 >= 1000 && $3 < 60000 && $3 > uid { uid = $3 } END { print uid + 1 }' "$passwd_file"
  else
    printf '1000\n'
  fi
}

create_user() {
  local root="$1"
  local passwd_file="$root/etc/passwd"
  local group_file="$root/etc/group"
  local home_dir="$root/home/$USER_NAME"
  local uid

  [[ -n "$USER_NAME" ]] || return 0
  valid_user "$USER_NAME" || die "bad user name: $USER_NAME"

  mkdir -p "$(dirname "$passwd_file")" "$(dirname "$group_file")" "$home_dir"
  [[ -f "$passwd_file" ]] || printf 'root:x:0:0:root:/root:/bin/sh\n' > "$passwd_file"
  [[ -f "$group_file" ]] || printf 'root:x:0:\n' > "$group_file"
  if grep -q "^$USER_NAME:" "$passwd_file"; then
    printf 'user exists: %s\n' "$USER_NAME"
    return 0
  fi

  uid="$(next_uid "$passwd_file")"
  printf '%s:x:%s:%s:Ooonana User:/home/%s:/bin/sh\n' "$USER_NAME" "$uid" "$uid" "$USER_NAME" >> "$passwd_file"
  printf '%s:x:%s:\n' "$USER_NAME" "$uid" >> "$group_file"
  chmod 755 "$home_dir" 2>/dev/null || true
  printf 'user created: %s\n' "$USER_NAME"
}

hash_password() {
  local password="$1"
  if command -v openssl >/dev/null 2>&1; then
    printf '%s\n' "$password" | openssl passwd -6 -stdin
    return 0
  fi
  if command -v python3 >/dev/null 2>&1; then
    printf '%s\n' "$password" | python3 -c 'import crypt, sys; pw = sys.stdin.readline().rstrip("\n"); print(crypt.crypt(pw, crypt.mksalt(crypt.METHOD_SHA512)))'
    return 0
  fi
  return 1
}

write_password() {
  local root="$1"
  local shadow_file="$root/etc/shadow"
  local tmp_file
  local hash
  local day

  [[ "$PASSWORD_STDIN" -eq 1 ]] || return 0
  [[ -n "$USER_NAME" ]] || die "--password-stdin requires --user NAME"
  [[ -n "$PASSWORD_VALUE" ]] || return 0

  hash="$(hash_password "$PASSWORD_VALUE")" || die "password hashing requires openssl or python3 crypt"
  day="$(($(date +%s) / 86400))"
  mkdir -p "$(dirname "$shadow_file")"
  [[ -f "$shadow_file" ]] || printf 'root:*:%s:0:99999:7:::\n' "$day" > "$shadow_file"
  tmp_file="$shadow_file.tmp.$$"
  if grep -q "^$USER_NAME:" "$shadow_file"; then
    awk -F: -v user="$USER_NAME" -v hash="$hash" -v day="$day" 'BEGIN { OFS = FS } $1 == user { $2 = hash; $3 = day } { print }' "$shadow_file" > "$tmp_file"
  else
    cat "$shadow_file" > "$tmp_file"
    printf '%s:%s:%s:0:99999:7:::\n' "$USER_NAME" "$hash" "$day" >> "$tmp_file"
  fi
  mv "$tmp_file" "$shadow_file"
  chmod 600 "$shadow_file" 2>/dev/null || true
  printf 'password set: %s\n' "$USER_NAME"
}

write_hostname() {
  local root="$1"
  [[ -n "$HOSTNAME_VALUE" ]] || return 0
  valid_hostname "$HOSTNAME_VALUE" || die "bad hostname: $HOSTNAME_VALUE"
  printf '%s\n' "$HOSTNAME_VALUE" > "$root/etc/hostname"
  cat > "$root/etc/hosts" <<EOF
127.0.0.1 localhost $HOSTNAME_VALUE
::1 localhost ip6-localhost ip6-loopback
EOF
  printf 'hostname: %s\n' "$HOSTNAME_VALUE"
}

write_theme() {
  local root="$1"
  [[ -n "$THEME" ]] || return 0
  case "$THEME" in
    dark|light) ;;
    *) die "theme must be dark or light" ;;
  esac
  mkdir -p "$root/etc/ooonana"
  printf '%s\n' "$THEME" > "$root/etc/ooonana/theme"
  cat > "$root/etc/ooonana/theme.conf" <<EOF
OOONANA_THEME="$THEME"
EOF
  printf 'theme: %s\n' "$THEME"
}

write_cloud_repo() {
  local root="$1"
  local source_file="$root/etc/ooonana/sources.d/cloud.repo"
  [[ -n "$CLOUD_REPO" ]] || return 0
  valid_repo_uri "$CLOUD_REPO" || die "bad cloud repo URI: $CLOUD_REPO"
  mkdir -p "$(dirname "$source_file")"
  cat > "$source_file" <<EOF
OOONANA_REPO_NAME="cloud"
OOONANA_REPO_URI="$CLOUD_REPO"
EOF
  printf 'cloud repo: %s\n' "$CLOUD_REPO"
}

apply_install_config() {
  local root="$1"
  create_user "$root"
  write_password "$root"
  write_hostname "$root"
  write_theme "$root"
  write_cloud_repo "$root"
}

prepare_target() {
  TARGET_MODE="$(detect_target_mode)"
  require_block_or_dry "$HOME_PART" "--home-part"
  require_block_or_dry "$SWAP_PART" "--swap-part"
  require_block_or_dry "$EFI_PART" "--efi-part"
  case "$TARGET_MODE" in
    disk)
      require_commands parted mkfs.ext4 mount rsync grub-install install
      if [[ "$DRY_RUN" -eq 1 ]]; then
        run_cmd parted -s "$TARGET" mklabel msdos mkpart primary ext4 1MiB 100% set 1 boot on
        run_cmd losetup --find --show --partscan "$TARGET"
        INSTALL_DEVICE="LOOP_DEVICE"
        TARGET_PART="LOOP_PARTITION"
      else
        parted -s "$TARGET" mklabel msdos mkpart primary ext4 1MiB 100% set 1 boot on
        if [[ -f "$TARGET" ]]; then
          require_commands losetup
          LOOP_DEV="$(losetup --find --show --partscan "$TARGET")"
          partprobe "$LOOP_DEV" 2>/dev/null || true
          INSTALL_DEVICE="$LOOP_DEV"
          TARGET_PART="$(partition_path "$LOOP_DEV")"
        else
          INSTALL_DEVICE="$TARGET"
          partprobe "$TARGET" 2>/dev/null || true
          TARGET_PART="$(partition_path "$TARGET")"
        fi
        wait_for_block "$TARGET_PART" || die "missing target partition: $TARGET_PART"
      fi
      ;;
    partition)
      require_commands mkfs.ext4 mount rsync
      INSTALL_DEVICE=""
      TARGET_PART="$TARGET"
      if [[ "$BOOTLOADER" == "grub" ]]; then
        die "--bootloader grub requires whole disk target"
      fi
      ;;
    *) die "unknown target mode: $TARGET_MODE" ;;
  esac

  if [[ "$TARGET_MODE" == "partition" && "$FORMAT_ROOT" -eq 0 ]]; then
    printf 'keep root filesystem: %s\n' "$TARGET_PART"
  else
    run_cmd mkfs.ext4 -F -L OOONANA_ROOT "$TARGET_PART"
  fi
  if [[ "$DRY_RUN" -eq 1 ]]; then
    TARGET_PARTUUID="TARGET_PARTUUID"
  elif [[ "$TARGET_MODE" == "disk" ]]; then
    require_commands blkid
    TARGET_PARTUUID="$(blkid -s PARTUUID -o value "$TARGET_PART" 2>/dev/null || true)"
    [[ -n "$TARGET_PARTUUID" ]] || die "missing PARTUUID for $TARGET_PART"
  fi
  run_cmd mkdir -p "$MOUNT_POINT"
  run_cmd mount "$TARGET_PART" "$MOUNT_POINT"
  mount_extra_partitions
}

install_bootloader() {
  local append
  case "$BOOTLOADER" in
    none) return 0 ;;
    auto)
      [[ "$TARGET_MODE" == "disk" ]] || return 0
      ;;
    grub)
      [[ "$TARGET_MODE" == "disk" ]] || die "--bootloader grub requires whole disk target"
      ;;
    *) die "bootloader must be auto, grub, or none" ;;
  esac

  install_kernel "$MOUNT_POINT"
  if [[ "$DRY_RUN" -eq 1 ]]; then
    append="$(kernel_append "PARTUUID=TARGET_PARTUUID")"
    printf 'grub.cfg: linux /boot/vmlinuz %s\n' "$append"
  else
    write_grub_config "$MOUNT_POINT" "PARTUUID=$TARGET_PARTUUID"
  fi
  run_cmd grub-install --target=i386-pc --boot-directory="$MOUNT_POINT/boot" --modules="part_msdos ext2" --no-floppy "$INSTALL_DEVICE"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --target) TARGET="$2"; shift 2 ;;
    --source) SOURCE="$2"; shift 2 ;;
    --mount-point) MOUNT_POINT="$2"; shift 2 ;;
    --hostname) HOSTNAME_VALUE="$2"; shift 2 ;;
    --user) USER_NAME="$2"; shift 2 ;;
    --theme) THEME="$2"; shift 2 ;;
    --cloud-repo) CLOUD_REPO="$2"; shift 2 ;;
    --password-stdin) PASSWORD_STDIN=1; shift ;;
    --kernel) KERNEL_PATH="$2"; shift 2 ;;
    --bootloader) BOOTLOADER="$2"; shift 2 ;;
    --home-part) HOME_PART="$2"; shift 2 ;;
    --swap-part) SWAP_PART="$2"; shift 2 ;;
    --efi-part) EFI_PART="$2"; shift 2 ;;
    --keep-root) FORMAT_ROOT=0; shift ;;
    --keep-home) FORMAT_HOME=0; shift ;;
    --keep-swap) FORMAT_SWAP=0; shift ;;
    --keep-efi) FORMAT_EFI=0; shift ;;
    --format-efi) FORMAT_EFI=1; shift ;;
    --smoke) SMOKE=1; shift ;;
    --gui-smoke) GUI_SMOKE=1; shift ;;
    --yes) YES=1; shift ;;
    --dry-run) DRY_RUN=1; shift ;;
    -h|--help) usage; exit 0 ;;
    *) die "unknown option: $1" ;;
  esac
done

[[ -n "$TARGET" ]] || die "--target required"
[[ "$YES" -eq 1 ]] || die "--yes required because install formats target"
case "$BOOTLOADER" in
  auto|grub|none) ;;
  *) die "bootloader must be auto, grub, or none" ;;
esac
[[ -z "$CLOUD_REPO" ]] || valid_repo_uri "$CLOUD_REPO" || die "bad cloud repo URI: $CLOUD_REPO"
if [[ "$PASSWORD_STDIN" -eq 1 && "$DRY_RUN" -eq 0 ]]; then
  IFS= read -r PASSWORD_VALUE || true
fi

if [[ "$DRY_RUN" -eq 0 ]]; then
  [[ "${EUID:-$(id -u)}" -eq 0 ]] || die "run as root"
  [[ -e "$TARGET" ]] || die "target missing: $TARGET"
  [[ -d "$SOURCE" ]] || die "source missing: $SOURCE"
  [[ -z "$KERNEL_PATH" || -f "$KERNEL_PATH" ]] || die "kernel missing: $KERNEL_PATH"
fi

cleanup() {
  if [[ "$DRY_RUN" -eq 0 ]] && mountpoint -q "$MOUNT_POINT/boot/efi" 2>/dev/null; then
    umount "$MOUNT_POINT/boot/efi"
  fi
  if [[ "$DRY_RUN" -eq 0 ]] && mountpoint -q "$MOUNT_POINT/home" 2>/dev/null; then
    umount "$MOUNT_POINT/home"
  fi
  if [[ "$DRY_RUN" -eq 0 ]] && mountpoint -q "$MOUNT_POINT"; then
    umount "$MOUNT_POINT"
  fi
  if [[ "$DRY_RUN" -eq 0 && -n "$LOOP_DEV" ]]; then
    losetup -d "$LOOP_DEV" 2>/dev/null || true
  fi
}
trap cleanup EXIT

prepare_target
run_cmd rsync -aHAX --numeric-ids \
  --exclude '/dev/*' \
  --exclude '/proc/*' \
  --exclude '/sys/*' \
  --exclude '/run/*' \
  --exclude '/tmp/*' \
  --exclude '/mnt/*' \
  --exclude '/media/*' \
  --exclude '/lost+found' \
  "$SOURCE"/ "$MOUNT_POINT"/

if [[ "$DRY_RUN" -eq 1 ]]; then
  [[ -z "$USER_NAME" ]] || printf 'create user %s\n' "$USER_NAME"
  [[ -z "$HOSTNAME_VALUE" ]] || printf 'write hostname %s\n' "$HOSTNAME_VALUE"
  [[ -z "$THEME" ]] || printf 'write theme %s\n' "$THEME"
  [[ -z "$CLOUD_REPO" ]] || printf 'write cloud repo %s\n' "$CLOUD_REPO"
  [[ "$PASSWORD_STDIN" -eq 0 ]] || printf 'read password from stdin\n'
  install_bootloader
  print_cmd mkdir -p "$MOUNT_POINT/var/lib/ooonana"
  print_cmd sh -c "printf 'installed\n' > '$MOUNT_POINT/var/lib/ooonana/install-ok'"
  write_fstab "$MOUNT_POINT"
  unmount_targets
else
  apply_install_config "$MOUNT_POINT"
  install_bootloader
  mkdir -p "$MOUNT_POINT/var/lib/ooonana"
  printf 'installed\n' > "$MOUNT_POINT/var/lib/ooonana/install-ok"
  write_fstab "$MOUNT_POINT"
  unmount_targets
fi

printf 'OOONANA_INSTALL_OK\n'
