#!/bin/sh
set -eu

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
for GAME in \
  "/usr/lib/ooonana/oonana_game.py" \
  "$SCRIPT_DIR/../lib/ooonana/oonana_game.py"
do
  if [ -x "$GAME" ] && command -v python3 >/dev/null 2>&1; then
    exec python3 "$GAME" "$@"
  fi
done

cat <<'EOF'
Ooonana brickout
python3 required for installer game engine
EOF
exit 1
