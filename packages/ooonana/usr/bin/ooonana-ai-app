#!/bin/sh
set -eu

AI_CMD="${OOONANA_AI_CMD:-ooonana-ai}"

open_xterm() {
  [ "${OOONANA_AI_APP_NO_X:-0}" = "1" ] && return 1
  [ "${OOONANA_AI_APP_TERMINAL:-0}" = "1" ] && return 1
  if command -v ooonana-theme-env >/dev/null 2>&1 && command -v xterm >/dev/null 2>&1; then
    exec ooonana-theme-env xterm -title "Ooonana AI" -e env OOONANA_AI_APP_TERMINAL=1 "$0" "$@"
  fi
  if command -v xterm >/dev/null 2>&1; then
    exec xterm -title "Ooonana AI" -e env OOONANA_AI_APP_TERMINAL=1 "$0" "$@"
  fi
  return 1
}

run_ai() {
  "$AI_CMD" "$@"
}

pause_if_interactive() {
  [ "${OOONANA_AI_APP_ONESHOT:-0}" = "1" ] && return 0
  [ -t 0 ] || return 0
  printf '\npress enter'
  IFS= read -r _ || true
}

print_dashboard() {
  printf 'Ooonana AI native app\n'
  printf '=====================\n\n'
  run_ai status || true
  printf '\nDesktop\n'
  printf 'display: %s\n' "${DISPLAY:-missing}"
  printf 'theme: %s\n' "${OOONANA_THEME:-auto}"
  printf '\nQuick actions\n'
  printf '1  chat\n'
  printf '2  ask\n'
  printf '3  tools\n'
  printf '4  tasks\n'
  printf '5  sessions\n'
  printf '6  setup\n'
  printf '7  shell\n'
  printf '8  desktop\n'
  printf '9  audit\n'
  printf '10 history\n'
  printf '11 provider\n'
  printf '12 model\n'
  printf '13 env\n'
  printf 'q quit\n'
}

run_action() {
  action="$1"
  shift || true
  case "$action" in
    1|chat)
      if command -v python3 >/dev/null 2>&1; then
        exec "$AI_CMD" chat "$@"
      fi
      printf 'python3 missing for chat. shell fallback.\n'
      exec /bin/sh
      ;;
    2|ask)
      prompt="${*:-}"
      if [ -z "$prompt" ]; then
        printf 'ask> '
        IFS= read -r prompt || prompt=""
      fi
      [ -n "$prompt" ] || return 0
      run_ai ask "$prompt"
      pause_if_interactive
      ;;
    3|tools)
      run_ai tools
      pause_if_interactive
      ;;
    4|tasks)
      run_ai tasks
      pause_if_interactive
      ;;
    5|sessions)
      run_ai sessions
      pause_if_interactive
      ;;
    6|setup)
      run_ai setup
      pause_if_interactive
      ;;
    status)
      run_ai status
      pause_if_interactive
      ;;
    history)
      run_ai history
      pause_if_interactive
      ;;
    audit)
      run_ai audit
      pause_if_interactive
      ;;
    7|shell)
      exec /bin/sh
      ;;
    8|desktop)
      run_ai tool desktop
      pause_if_interactive
      ;;
    9|audit)
      run_ai audit
      pause_if_interactive
      ;;
    10|history)
      run_ai history
      pause_if_interactive
      ;;
    11|provider)
      run_ai provider
      pause_if_interactive
      ;;
    12|model)
      run_ai model
      pause_if_interactive
      ;;
    13|env)
      run_ai env
      pause_if_interactive
      ;;
    q|quit|exit)
      exit 0
      ;;
    *)
      printf 'unknown action: %s\n' "$action" >&2
      return 1
      ;;
  esac
}

main_loop() {
  while :; do
    print_dashboard
    [ "${OOONANA_AI_APP_ONESHOT:-0}" = "1" ] && exit 0
    printf '\nchoice> '
    IFS= read -r choice || exit 0
    [ -n "$choice" ] || choice="chat"
    run_action "$choice"
    printf '\n'
  done
}

open_xterm "$@" || true

if [ -n "${OOONANA_AI_APP_COMMAND:-}" ]; then
  run_action "$OOONANA_AI_APP_COMMAND" "$@"
  exit $?
fi

if [ "$#" -gt 0 ]; then
  run_action "$@"
  exit $?
fi

main_loop
