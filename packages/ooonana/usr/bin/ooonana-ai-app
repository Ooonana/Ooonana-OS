#!/bin/sh
set -eu

AI_CMD="${OOONANA_AI_CMD:-ooonana-ai}"
APP_LOG="${OOONANA_AI_APP_LOG:-${XDG_STATE_HOME:-${HOME:-/tmp}/.local/state}/ooonana/ai-app.log}"

if [ "${1:-}" = "--dry-run" ]; then
  printf 'yad Ooonana AI dashboard\n'
  printf 'actions: status provider model tools tasks audit history desktop desktop-control permissions logs chat ask sessions setup env shell\n'
  printf 'dashboard tabs: home actions ask provider-model logs\n'
  printf 'dashboard sections: Home Ask Chat Tools Desktop Permissions Logs\n'
  printf 'grouped actions: Prompt Health Config Tools Desktop Logs Safety Terminal\n'
  printf 'icon command center: ask chat status tools desktop settings logs shell\n'
  printf 'AI workbench layout\n'
  printf 'workbench panes: Chat ActionRail Context Permissions Logs\n'
  printf 'chat-first controls: prompt transcript model provider tools save clear\n'
  printf 'persistent GUI loop: returns to actions after each action\n'
  printf 'gui chat: transcript prompt loop buttons ask status model provider tools clear save close\n'
  printf 'direct gui action: chat opens chat window immediately\n'
  printf 'gui controls: ask form provider/model action launcher desktop-control permissions logs\n'
  printf 'OOONANA_AI_CHAT_GUI_OK\n'
  printf 'permissions: shell actions gated; desktop actions explicit; logs: %s\n' "$APP_LOG"
  printf 'OOONANA_AI_APP_GUI_OK\n'
  exit 0
fi

open_xterm() {
  [ "${OOONANA_AI_APP_NO_X:-0}" = "1" ] && return 1
  [ "${OOONANA_AI_APP_TERMINAL:-0}" = "1" ] && return 1
  if command -v ooonana-theme-env >/dev/null 2>&1 && command -v xterm >/dev/null 2>&1; then
    exec ooonana-theme-env xterm -title "Ooonana AI" -e env OOONANA_AI_APP_TERMINAL=1 "$0" "$@"
  fi
  if command -v xterm >/dev/null 2>&1; then
    exec xterm -title "Ooonana AI" -e env OOONANA_AI_APP_TERMINAL=1 "$0" "$@"
  fi
  return 1
}

open_action_terminal() {
  title="Ooonana AI"
  [ "$#" -gt 0 ] && title="Ooonana AI: $1"
  if command -v ooonana-theme-env >/dev/null 2>&1 && command -v xterm >/dev/null 2>&1; then
    exec ooonana-theme-env xterm -title "$title" -e env OOONANA_AI_APP_TERMINAL=1 "$0" "$@"
  fi
  if command -v xterm >/dev/null 2>&1; then
    exec xterm -title "$title" -e env OOONANA_AI_APP_TERMINAL=1 "$0" "$@"
  fi
  return 1
}

run_ai() {
  "$AI_CMD" "$@"
}

log_event() {
  mkdir -p "$(dirname "$APP_LOG")" 2>/dev/null || return 0
  printf '%s %s\n' "$(date '+%Y-%m-%dT%H:%M:%S%z' 2>/dev/null || echo time)" "$*" >>"$APP_LOG" 2>/dev/null || true
}

run_gui_text() {
  title="$1"
  shift
  tmp="${TMPDIR:-/tmp}/ooonana-ai-app.$$"
  log_event "run: ooonana-ai $*"
  if run_ai "$@" >"$tmp" 2>&1; then
    :
  else
    rc="$?"
    {
      printf 'command failed: ooonana-ai'
      for arg in "$@"; do
        printf ' %s' "$arg"
      done
      printf '\nexit: %s\n\n' "$rc"
      cat "$tmp" 2>/dev/null || true
    } >"$tmp.fail"
    mv "$tmp.fail" "$tmp"
  fi
  yad --center --title "$title" --width=760 --height=520 --text-info --filename="$tmp" 2>/dev/null || true
  rm -f "$tmp" "$tmp.fail"
}

render_status() {
  printf 'Status panel\n'
  printf '============\n\n'
  run_ai status || true
  printf '\nProvider\n'
  run_ai provider 2>/dev/null || true
  printf '\nModel\n'
  run_ai model 2>/dev/null || true
  printf '\nDesktop\n'
  printf 'display: %s\n' "${DISPLAY:-missing}"
  printf 'theme: %s\n' "${OOONANA_THEME:-auto}"
  printf '\ntools registry: ooonana ai tools\n'
}

show_gui_status() {
  tmp="${TMPDIR:-/tmp}/ooonana-ai-status.$$"
  render_status >"$tmp" 2>&1 || true
  yad --center --title "Ooonana AI Status" --width=760 --height=520 --text-info --filename="$tmp" 2>/dev/null || true
  rm -f "$tmp"
}

show_home() {
  tmp="${TMPDIR:-/tmp}/ooonana-ai-home.$$"
  render_status >"$tmp" 2>&1 || true
  {
    printf '\nActions\n'
    printf '=======\n'
    printf 'Ask, Chat, Tools, Tasks, Provider/Model, Audit, History, Desktop, Desktop Control, Permissions, Logs, Setup, Env, Shell\n'
  } >>"$tmp"
  yad --center --title "Ooonana AI" --width=820 --height=560 \
    --text-info --filename="$tmp" --button=Actions:0 --button=Close:1 2>/dev/null
  rc="$?"
  rm -f "$tmp"
  return "$rc"
}

show_workbench() {
  tmp="${TMPDIR:-/tmp}/ooonana-ai-workbench.$$"
  {
    printf 'Ooonana AI Workbench\n'
    printf '====================\n\n'
    render_status
    printf '\nWorkbench panes: Chat | ActionRail | Context | Permissions | Logs\n'
    printf 'Chat-first controls: prompt transcript model provider tools save clear\n'
  } >"$tmp"
  yad --center --title "Ooonana AI Workbench" --width=900 --height=640 \
    --text-info --filename="$tmp" \
    --button=Chat:0 --button=Ask:2 --button=Actions:3 --button=Context:4 \
    --button=Permissions:5 --button=Logs:6 --button=Close:1 2>/dev/null
  rc="$?"
  rm -f "$tmp"
  return "$rc"
}

choose_action() {
  yad --center --title "Ooonana AI Actions" --width=780 --height=560 \
    --list --print-column=2 --column Icon --column Action --column Group --column Description \
    "" ask Prompt "Ask one prompt from a GUI form" \
    "" chat Prompt "Open GUI chat" \
    "" status Health "Provider, model, desktop, and health" \
    "" provider-model Config "Show provider and model together" \
    "" tools Tools "Show local tool registry" \
    "" tasks Tools "Show task board" \
    "" sessions Memory "Saved chat sessions" \
    "" audit Logs "Show audit log" \
    "" history Logs "Show prompt history" \
    "" desktop Desktop "Inspect desktop context" \
    "" desktop-control Desktop "Open terminal, browser, files, settings, or restart i3" \
    "" permissions Safety "Show action permissions and shell gate" \
    "" logs Logs "Open Ooonana AI app log" \
    "" setup Config "Configure provider keys" \
    "" env Config "Environment check" \
    "" shell Terminal "Fallback shell" 2>/dev/null || true
}

choose_workbench_action() {
  choose_action
}

ask_gui() {
  prompt="$(yad --center --title "Ask Ooonana AI" --width=720 --height=260 \
    --form --text "Prompt" --field="Prompt:TXT" "" \
    --button=Cancel:1 --button=Ask:0 2>/dev/null || true)"
  [ -n "$prompt" ] || return 0
  prompt="${prompt%|}"
  [ -n "$prompt" ] || return 0
  run_gui_text "Ooonana AI Answer" ask "$prompt"
}

chat_gui() {
  [ -n "${DISPLAY:-}" ] || return 1
  command -v yad >/dev/null 2>&1 || return 1

  transcript="${OOONANA_AI_CHAT_TRANSCRIPT:-${XDG_STATE_HOME:-${HOME:-/tmp}/.local/state}/ooonana/ai-chat-gui.txt}"
  mkdir -p "$(dirname "$transcript")" 2>/dev/null || true
  if [ ! -f "$transcript" ]; then
    {
      printf 'Ooonana AI GUI chat\n'
      printf '===================\n\n'
    } >"$transcript"
  fi

  while :; do
    if yad --center --title "Ooonana AI Chat" --width=860 --height=620 \
      --text-info --filename="$transcript" \
      --button=Ask:0 --button=Status:2 --button=Model:3 --button=Provider:4 \
      --button=Tools:5 --button=Clear:6 --button=Save:7 --button=Close:1 2>/dev/null; then
      rc=0
    else
      rc="$?"
    fi

    case "$rc" in
      0)
        prompt="$(yad --center --title "Ooonana AI Chat" --width=760 --height=300 \
          --form --text "Message" --field="Prompt:TXT" "" \
          --button=Cancel:1 --button=Ask:0 2>/dev/null || true)"
        prompt="${prompt%|}"
        [ -n "$prompt" ] || continue
        tmp="${TMPDIR:-/tmp}/ooonana-ai-chat.$$"
        {
          printf '\nYou\n---\n%s\n\nOoonana\n-------\n' "$prompt"
        } >>"$transcript"
        log_event "chat-gui ask"
        if run_ai ask "$prompt" >"$tmp" 2>&1; then
          cat "$tmp" >>"$transcript"
        else
          rc_ai="$?"
          printf 'command failed: ooonana-ai ask\nexit: %s\n' "$rc_ai" >>"$transcript"
          cat "$tmp" >>"$transcript" 2>/dev/null || true
        fi
        printf '\n' >>"$transcript"
        rm -f "$tmp"
        ;;
      2)
        run_gui_text "Ooonana AI Status" status
        ;;
      3)
        run_gui_text "Ooonana AI Model" model
        ;;
      4)
        run_gui_text "Ooonana AI Provider" provider
        ;;
      5)
        run_gui_text "Ooonana AI Tools" tools
        ;;
      6)
        {
          printf 'Ooonana AI GUI chat\n'
          printf '===================\n\n'
        } >"$transcript"
        ;;
      7)
        dest="$(yad --center --title "Save Ooonana AI Chat" --file --save \
          --filename="${HOME:-/tmp}/ooonana-ai-chat.txt" 2>/dev/null || true)"
        [ -n "$dest" ] && cp "$transcript" "$dest" 2>/dev/null || true
        ;;
      *)
        return 0
        ;;
    esac
  done
}

provider_model_gui() {
  tmp="${TMPDIR:-/tmp}/ooonana-ai-provider-model.$$"
  {
    printf 'Provider\n'
    printf '========\n'
    run_ai provider 2>&1 || true
    printf '\nModel\n'
    printf '=====\n'
    run_ai model 2>&1 || true
    printf '\nModels\n'
    printf '======\n'
    run_ai models 2>&1 || true
  } >"$tmp"
  yad --center --title "Ooonana AI Provider / Model" --width=760 --height=520 \
    --text-info --filename="$tmp" 2>/dev/null || true
  rm -f "$tmp"
}

context_gui() {
  tmp="${TMPDIR:-/tmp}/ooonana-ai-context.$$"
  {
    printf 'Ooonana AI context\n'
    printf '==================\n\n'
    printf '[desktop]\n'
    run_ai tool desktop 2>&1 || true
    printf '\n[tools]\n'
    run_ai tools 2>&1 || true
    printf '\n[tasks]\n'
    run_ai tasks 2>&1 || true
  } >"$tmp"
  yad --center --title "Ooonana AI Context" --width=820 --height=560 \
    --text-info --filename="$tmp" 2>/dev/null || true
  rm -f "$tmp"
}

permissions_gui() {
  tmp="${TMPDIR:-/tmp}/ooonana-ai-permissions.$$"
  {
    printf 'Ooonana AI permissions\n'
    printf '======================\n\n'
    printf 'ask/chat: allowed with configured provider key\n'
    printf 'desktop inspect: read-only\n'
    printf 'desktop control: explicit button choice only\n'
    printf 'shell tool: blocked unless command uses --yes\n'
    printf 'logs: %s\n' "$APP_LOG"
  } >"$tmp"
  yad --center --title "Ooonana AI Permissions" --width=700 --height=420 \
    --text-info --filename="$tmp" 2>/dev/null || true
  rm -f "$tmp"
}

logs_gui() {
  mkdir -p "$(dirname "$APP_LOG")" 2>/dev/null || true
  [ -f "$APP_LOG" ] || printf 'log created\n' >"$APP_LOG"
  yad --center --title "Ooonana AI Logs" --width=760 --height=520 \
    --text-info --filename="$APP_LOG" 2>/dev/null || true
}

desktop_control_gui() {
  action="$(yad --center --title "Ooonana Desktop Control" --width=600 --height=360 \
    --list --print-column=1 --column Action --column Description \
    " terminal" "Open themed terminal" \
    " browser" "Open Chromium" \
    " files" "Open Nemo file manager" \
    " settings" "Open Ooonana Settings" \
    " restart-i3" "Restart i3 window manager" 2>/dev/null || true)"
  [ -n "$action" ] || return 0
  log_event "desktop-control: $action"
  case "$action" in
    *terminal*) open_action_terminal shell || true ;;
    *browser*) command -v ooonana-browser >/dev/null 2>&1 && ooonana-browser || true ;;
    *files*) command -v ooonana-files >/dev/null 2>&1 && ooonana-files || true ;;
    *settings*) command -v ooonana-settings >/dev/null 2>&1 && ooonana-settings || true ;;
    *restart-i3*) command -v i3-msg >/dev/null 2>&1 && i3-msg restart >/dev/null 2>&1 || true ;;
  esac
}

open_gui() {
  [ "${OOONANA_AI_APP_NO_X:-0}" = "1" ] && return 1
  [ "${OOONANA_AI_APP_GUI:-1}" = "1" ] || return 1
  [ "${OOONANA_AI_APP_TERMINAL:-0}" = "1" ] && return 1
  [ -n "${DISPLAY:-}" ] || return 1
  command -v yad >/dev/null 2>&1 || return 1

  while :; do
    show_workbench
    rc="$?"
    case "$rc" in
      0)
        chat_gui || open_action_terminal chat || return 1
        continue
        ;;
      2)
        ask_gui
        continue
        ;;
      4)
        context_gui
        continue
        ;;
      5)
        permissions_gui
        continue
        ;;
      6)
        logs_gui
        continue
        ;;
      1|252)
        exit 0
        ;;
    esac
    action="$(choose_workbench_action)"
    [ -n "$action" ] || exit 0

    case "$action" in
      provider-model)
        provider_model_gui
        ;;
      status)
        show_gui_status
        ;;
      tools)
        run_gui_text "Ooonana AI Tools" tools
        ;;
      tasks)
        run_gui_text "Ooonana AI Tasks" tasks
        ;;
      sessions)
        run_gui_text "Ooonana AI Sessions" sessions
        ;;
      desktop)
        run_gui_text "Ooonana AI Desktop" tool desktop
        ;;
      context)
        context_gui
        ;;
      desktop-control)
        desktop_control_gui
        ;;
      permissions)
        permissions_gui
        ;;
      logs)
        logs_gui
        ;;
      audit)
        run_gui_text "Ooonana AI Audit" audit
        ;;
      history)
        run_gui_text "Ooonana AI History" history
        ;;
      provider)
        run_gui_text "Ooonana AI Provider" provider
        ;;
      model)
        run_gui_text "Ooonana AI Model" model
        ;;
      env)
        run_gui_text "Ooonana AI Env" env
        ;;
      ask)
        ask_gui
        ;;
      shell)
        open_action_terminal shell || return 1
        ;;
      chat)
        chat_gui || open_action_terminal chat || return 1
        ;;
      setup)
        open_action_terminal setup || return 1
        ;;
      *)
        open_action_terminal "$action" || return 1
        ;;
    esac
  done
}

open_requested_gui_action() {
  [ "${OOONANA_AI_APP_NO_X:-0}" = "1" ] && return 1
  [ "${OOONANA_AI_APP_GUI:-1}" = "1" ] || return 1
  [ "${OOONANA_AI_APP_TERMINAL:-0}" = "1" ] && return 1
  [ -n "${DISPLAY:-}" ] || return 1
  command -v yad >/dev/null 2>&1 || return 1

  case "${1:-}" in
    chat)
      shift
      chat_gui "$@"
      exit 0
      ;;
    ask)
      shift
      ask_gui "$@"
      exit 0
      ;;
    *)
      return 1
      ;;
  esac
}

pause_if_interactive() {
  [ "${OOONANA_AI_APP_ONESHOT:-0}" = "1" ] && return 0
  [ -t 0 ] || return 0
  printf '\npress enter'
  IFS= read -r _ || true
}

print_dashboard() {
  printf 'Ooonana AI native app\n'
  printf '=====================\n\n'
  render_status
  printf '\nQuick actions\n'
  printf '0  status\n'
  printf '1  chat\n'
  printf '2  ask\n'
  printf '3  tools\n'
  printf '4  tasks\n'
  printf '5  sessions\n'
  printf '6  setup\n'
  printf '7  shell\n'
  printf '8  desktop\n'
  printf '9  audit\n'
  printf '10 history\n'
  printf '11 provider\n'
  printf '12 model\n'
  printf '13 env\n'
  printf '14 permissions\n'
  printf '15 logs\n'
  printf '16 desktop-control\n'
  printf 'q quit\n'
}

run_action() {
  action="$1"
  shift || true
  case "$action" in
    1|chat)
      if command -v python3 >/dev/null 2>&1; then
        exec "$AI_CMD" chat "$@"
      fi
      printf 'python3 missing for chat. shell fallback.\n'
      exec /bin/sh
      ;;
    2|ask)
      prompt="${*:-}"
      if [ -z "$prompt" ]; then
        printf 'ask> '
        IFS= read -r prompt || prompt=""
      fi
      [ -n "$prompt" ] || return 0
      run_ai ask "$prompt"
      pause_if_interactive
      ;;
    3|tools)
      run_ai tools
      pause_if_interactive
      ;;
    4|tasks)
      run_ai tasks
      pause_if_interactive
      ;;
    5|sessions)
      run_ai sessions
      pause_if_interactive
      ;;
    6|setup)
      run_ai setup
      pause_if_interactive
      ;;
    status)
      run_ai status
      pause_if_interactive
      ;;
    history)
      run_ai history
      pause_if_interactive
      ;;
    audit)
      run_ai audit
      pause_if_interactive
      ;;
    7|shell)
      exec /bin/sh
      ;;
    8|desktop)
      run_ai tool desktop
      pause_if_interactive
      ;;
    9|audit)
      run_ai audit
      pause_if_interactive
      ;;
    10|history)
      run_ai history
      pause_if_interactive
      ;;
    11|provider)
      run_ai provider
      pause_if_interactive
      ;;
    12|model)
      run_ai model
      pause_if_interactive
      ;;
    13|env)
      run_ai env
      pause_if_interactive
      ;;
    14|permissions)
      printf 'permissions: shell blocked unless --yes; desktop control requires explicit action\n'
      printf 'log: %s\n' "$APP_LOG"
      pause_if_interactive
      ;;
    15|logs)
      mkdir -p "$(dirname "$APP_LOG")" 2>/dev/null || true
      [ -f "$APP_LOG" ] || printf 'log created\n' >"$APP_LOG"
      cat "$APP_LOG"
      pause_if_interactive
      ;;
    16|desktop-control)
      printf 'desktop-control: terminal browser files settings restart-i3\n'
      pause_if_interactive
      ;;
    0|status)
      render_status
      pause_if_interactive
      ;;
    q|quit|exit)
      exit 0
      ;;
    *)
      printf 'unknown action: %s\n' "$action" >&2
      return 1
      ;;
  esac
}

main_loop() {
  while :; do
    print_dashboard
    [ "${OOONANA_AI_APP_ONESHOT:-0}" = "1" ] && exit 0
    printf '\nchoice> '
    IFS= read -r choice || exit 0
    [ -n "$choice" ] || choice="chat"
    run_action "$choice"
    printf '\n'
  done
}

if open_requested_gui_action "$@"; then
  exit 0
fi
if open_gui "$@"; then
  exit 0
fi
if open_xterm "$@"; then
  exit 0
fi

if [ -n "${OOONANA_AI_APP_COMMAND:-}" ]; then
  run_action "$OOONANA_AI_APP_COMMAND" "$@"
  exit $?
fi

if [ "$#" -gt 0 ]; then
  run_action "$@"
  exit $?
fi

main_loop
