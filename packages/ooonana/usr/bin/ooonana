usage() {
  usage_main
}

cmd_help() {
  topic="${1:-}"
  case "$topic" in
    ""|main|overview) usage_main ;;
    packages|pkg|package) usage_packages ;;
    get|install) usage_get ;;
    upgrade) usage_upgrade ;;
    remove|purge|uninstall) usage_remove ;;
    fix|repair) usage_upgrade ;;
    repo|repos|sources) usage_repo_help ;;
    ai|agent|agents) usage_ai_help ;;
    ui|gui|i3|theme|desktop) usage_ui_help ;;
    all)
      usage_main
      printf '\n'
      usage_packages
      printf '\n'
      usage_ai_help
      printf '\n'
      usage_ui_help
      ;;
    *) die "unknown help topic: $topic" ;;
  esac
}

have() {
  command -v "$1" >/dev/null 2>&1
}

die() {
  printf 'ooonana: %s\n' "$*" >&2
  exit 1
}

ensure_pkg_dirs() {
  mkdir -p "$INSTALLED_DIR" "$CACHE_DIR"
}

reset_pkg_vars() {
  OOONANA_PKG_ID=""
  OOONANA_PKG_VERSION=""
  OOONANA_PKG_SUMMARY=""
  OOONANA_PKG_DEPS=""
  OOONANA_PKG_CONFLICTS=""
  OOONANA_PKG_KIND=""
  OOONANA_PKG_COMPONENTS=""
  OOONANA_PKG_NOTES=""
  OOONANA_PKG_ARCHIVE=""
  OOONANA_PKG_SHA256=""
  LOADED_PKG_FILE=""
  LOADED_REPO_DIR=""
  LOADED_REPO_NAME=""
  LOADED_REPO_URI=""
  LOADED_REPO_KEY=""
}

reset_repo_vars() {
  OOONANA_REPO_NAME=""
  OOONANA_REPO_URI=""
  OOONANA_REPO_KEY=""
}

repo_uri_path() {
  uri="$1"
  case "$uri" in
    file://*) printf '%s\n' "${uri#file://}" ;;
    http://*|https://*) printf '%s\n' "$uri" ;;
    *) printf '%s\n' "$uri" ;;
  esac
}

repo_is_remote() {
  case "$1" in
    http://*|https://*) return 0 ;;
    *) return 1 ;;
  esac
}

repo_is_tarball() {
  case "$1" in
    *.tar.gz|*.tgz) return 0 ;;
    *) return 1 ;;
  esac
}

repo_cache_dir() {
  printf '%s/repos/%s\n' "$CACHE_DIR" "$1"
}

assert_repo_cache_path() {
  path="$1"
  case "$path" in
    "$CACHE_DIR"/repos/*) return 0 ;;
    *) die "unsafe repo cache path: $path" ;;
  esac
}

github_token() {
  token="${OOONANA_REPO_TOKEN:-}"
  [ -n "$token" ] || token="${OOONANA_GITHUB_TOKEN:-}"
  [ -n "$token" ] || token="${GITHUB_TOKEN:-}"
  [ -n "$token" ] || return 1
  printf '%s\n' "$token"
}

github_release_parts() {
  url="$1"
  case "$url" in
    https://github.com/*/releases/download/*) ;;
    *) return 1 ;;
  esac
  rest="${url#https://github.com/}"
  owner="${rest%%/*}"
  rest="${rest#*/}"
  repo="${rest%%/*}"
  rest="${rest#*/releases/download/}"
  tag="${rest%%/*}"
  asset="${rest#*/}"
  [ -n "$owner" ] && [ -n "$repo" ] && [ -n "$tag" ] && [ -n "$asset" ] || return 1
  printf '%s\t%s\t%s\t%s\n' "$owner" "$repo" "$tag" "$asset"
}

extract_github_asset_api_url() {
  wanted="$1"
  meta="$2"
  tr ',' '\n' < "$meta" | awk -v wanted="$wanted" '
    /"url"[ ]*:[ ]*"https:\/\/api.github.com\/repos\/.*\/releases\/assets\// {
      line = $0
      sub(/^.*"url"[ ]*:[ ]*"/, "", line)
      sub(/".*$/, "", line)
      url = line
      if (name == wanted) {
        print url
        exit
      }
    }
    /"name"[ ]*:[ ]*"/ {
      line = $0
      sub(/^.*"name"[ ]*:[ ]*"/, "", line)
      sub(/".*$/, "", line)
      name = line
      if (line == wanted && url != "") {
        print url
        exit
      }
    }
  '
}

download_github_release_asset() {
  url="$1"
  out="$2"
  parts="$(github_release_parts "$url" 2>/dev/null || true)"
  [ -n "$parts" ] || return 1
  token="$(github_token 2>/dev/null || true)"
  [ -n "$token" ] || return 1
  have curl || die "private GitHub release repo needs curl"

  old_ifs="$IFS"
  IFS='	'
  set -- $parts
  IFS="$old_ifs"
  owner="$1"
  repo="$2"
  tag="$3"
  asset="$4"
  meta="$out.github-release.$$"
  api_url="https://api.github.com/repos/$owner/$repo/releases/tags/$tag"

  curl -fsSL \
    -H "Authorization: Bearer $token" \
    -H "Accept: application/vnd.github+json" \
    -H "User-Agent: ooonana" \
    "$api_url" \
    -o "$meta" || {
      rm -f "$meta"
      return 1
    }
  asset_api_url="$(extract_github_asset_api_url "$asset" "$meta")"
  rm -f "$meta"
  [ -n "$asset_api_url" ] || die "GitHub release asset missing: $owner/$repo $tag $asset"
  curl -fsSL \
    -H "Authorization: Bearer $token" \
    -H "Accept: application/octet-stream" \
    -H "User-Agent: ooonana" \
    "$asset_api_url" \
    -o "$out"
}

download_file() {
  url="$1"
  out="$2"
  mkdir -p "$(dirname "$out")"
  if download_github_release_asset "$url" "$out"; then
    return 0
  fi
  if have curl; then
    curl -fsSL "$url" -o "$out"
  elif have wget; then
    wget -q -O "$out" "$url"
  else
    die "missing downloader: curl or wget"
  fi
}

remote_repo_url() {
  uri="$1"
  rel="$2"
  printf '%s/%s\n' "${uri%/}" "$rel"
}

remote_repo_cache_file() {
  repo_name="$1"
  repo_uri="$2"
  rel="$3"
  cache_dir="$(repo_cache_dir "$repo_name")"
  target="$cache_dir/$rel"
  download_file "$(remote_repo_url "$repo_uri" "$rel")" "$target"
  printf '%s\n' "$target"
}

sync_remote_repo() {
  repo_name="$1"
  repo_uri="$2"
  cache_dir="$(repo_cache_dir "$repo_name")"
  mkdir -p "$cache_dir"
  download_file "$(remote_repo_url "$repo_uri" index.tsv)" "$cache_dir/index.tsv"
  download_file "$(remote_repo_url "$repo_uri" SHA256SUMS)" "$cache_dir/SHA256SUMS"
  rm -f "$cache_dir/SHA256SUMS.sig"
  download_file "$(remote_repo_url "$repo_uri" SHA256SUMS.sig)" "$cache_dir/SHA256SUMS.sig" 2>/dev/null || true
  printf '%s\n' "$cache_dir"
}

validate_repo_tarball_entries() {
  repo_name="$1"
  tarball="$2"
  have tar || die "missing command: tar"
  tar_list_archive "$tarball" | while IFS= read -r entry; do
    clean_entry="${entry#./}"
    [ -n "$clean_entry" ] || continue
    case "$clean_entry" in
      /*|../*|*/../*|..)
        die "unsafe repo tarball path in $repo_name: $entry"
        ;;
    esac
  done
}

sync_tarball_repo() {
  repo_name="$1"
  repo_uri="$2"
  cache_dir="$(repo_cache_dir "$repo_name")"
  parent_dir="$(dirname "$cache_dir")"
  tmp_dir="$parent_dir/$repo_name.tmp.$$"
  tarball="$tmp_dir/repo.tar.gz"

  assert_repo_cache_path "$cache_dir"
  assert_repo_cache_path "$tmp_dir"
  rm -rf "$tmp_dir"
  mkdir -p "$tmp_dir/root" "$parent_dir"

  if repo_is_remote "$repo_uri"; then
    download_file "$repo_uri" "$tarball"
  else
    [ -f "$repo_uri" ] || die "missing repo tarball: $repo_name $repo_uri"
    cp "$repo_uri" "$tarball"
  fi
  validate_repo_tarball_entries "$repo_name" "$tarball"
  tar -xzf "$tarball" -C "$tmp_dir/root"

  repo_root="$tmp_dir/root"
  if [ ! -f "$repo_root/index.tsv" ]; then
    first_dir="$(find "$repo_root" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | sed -n '1p')"
    if [ -n "$first_dir" ] && [ -f "$first_dir/index.tsv" ]; then
      repo_root="$first_dir"
    fi
  fi
  [ -f "$repo_root/index.tsv" ] || die "repo tarball missing index.tsv: $repo_name"
  [ -f "$repo_root/SHA256SUMS" ] || die "repo tarball missing SHA256SUMS: $repo_name"

  rm -rf "$cache_dir"
  mv "$repo_root" "$cache_dir"
  rm -rf "$tmp_dir"
  printf '%s\n' "$cache_dir"
}

remote_repo_cached_dir() {
  repo_name="$1"
  repo_uri="$2"
  cache_dir="$(repo_cache_dir "$repo_name")"
  if [ ! -f "$cache_dir/index.tsv" ] || [ ! -f "$cache_dir/SHA256SUMS" ]; then
    sync_remote_repo "$repo_name" "$repo_uri" >/dev/null
  fi
  printf '%s\n' "$cache_dir"
}

tarball_repo_cached_dir() {
  repo_name="$1"
  repo_uri="$2"
  cache_dir="$(repo_cache_dir "$repo_name")"
  if [ ! -f "$cache_dir/index.tsv" ] || [ ! -f "$cache_dir/SHA256SUMS" ]; then
    sync_tarball_repo "$repo_name" "$repo_uri" >/dev/null
  fi
  printf '%s\n' "$cache_dir"
}

load_repo_source_file() {
  source_file="$1"
  reset_repo_vars
  . "$source_file"
  [ -n "$OOONANA_REPO_NAME" ] || OOONANA_REPO_NAME="$(basename "$source_file" .repo)"
  [ -n "$OOONANA_REPO_URI" ] || die "repo source missing OOONANA_REPO_URI: $source_file"
  case "$OOONANA_REPO_NAME" in
    *[!A-Za-z0-9_.-]*|"") die "bad repo source name: $OOONANA_REPO_NAME" ;;
  esac
  OOONANA_REPO_URI="$(repo_uri_path "$OOONANA_REPO_URI")"
  [ -z "$OOONANA_REPO_KEY" ] || [ -f "$OOONANA_REPO_KEY" ] || die "repo key missing: $OOONANA_REPO_KEY"
}

repo_sources() {
  printf 'builtin\t%s\t%s\n' "$REPO_DIR" "${OOONANA_BUILTIN_REPO_KEY:-}"
  [ -d "$SOURCES_DIR" ] || return 0
  for source_file in "$SOURCES_DIR"/*.repo; do
    [ -f "$source_file" ] || continue
    load_repo_source_file "$source_file"
    printf '%s\t%s\t%s\n' "$OOONANA_REPO_NAME" "$OOONANA_REPO_URI" "$OOONANA_REPO_KEY"
  done
}

find_pkg_file() {
  id="$1"
  if [ -f "$REPO_DIR/$id.pkg" ]; then
    LOADED_PKG_FILE="$REPO_DIR/$id.pkg"
    LOADED_REPO_DIR="$REPO_DIR"
    LOADED_REPO_NAME="builtin"
    LOADED_REPO_KEY="${OOONANA_BUILTIN_REPO_KEY:-}"
    return 0
  fi

  [ -d "$SOURCES_DIR" ] || return 1
  for source_file in "$SOURCES_DIR"/*.repo; do
    [ -f "$source_file" ] || continue
    load_repo_source_file "$source_file"
    if repo_is_tarball "$OOONANA_REPO_URI"; then
      remote_dir="$(tarball_repo_cached_dir "$OOONANA_REPO_NAME" "$OOONANA_REPO_URI")"
      if [ -f "$remote_dir/index.tsv" ] && awk -v id="$id" 'BEGIN { FS = "\t" } $1 == id { found = 1 } END { exit found ? 0 : 1 }' "$remote_dir/index.tsv"; then
        [ -f "$remote_dir/$id.pkg" ] || die "missing repo file: $id.pkg"
        LOADED_PKG_FILE="$remote_dir/$id.pkg"
        LOADED_REPO_DIR="$remote_dir"
        LOADED_REPO_NAME="$OOONANA_REPO_NAME"
        LOADED_REPO_KEY="$OOONANA_REPO_KEY"
        return 0
      fi
    elif repo_is_remote "$OOONANA_REPO_URI"; then
      remote_dir="$(remote_repo_cached_dir "$OOONANA_REPO_NAME" "$OOONANA_REPO_URI")"
      if [ -f "$remote_dir/index.tsv" ] && awk -v id="$id" 'BEGIN { FS = "\t" } $1 == id { found = 1 } END { exit found ? 0 : 1 }' "$remote_dir/index.tsv"; then
        remote_repo_cache_file "$OOONANA_REPO_NAME" "$OOONANA_REPO_URI" "$id.pkg" >/dev/null
        LOADED_PKG_FILE="$remote_dir/$id.pkg"
        LOADED_REPO_DIR="$remote_dir"
        LOADED_REPO_NAME="$OOONANA_REPO_NAME"
        LOADED_REPO_URI="$OOONANA_REPO_URI"
        LOADED_REPO_KEY="$OOONANA_REPO_KEY"
        return 0
      fi
    else
      [ -d "$OOONANA_REPO_URI" ] || die "missing repo source: $OOONANA_REPO_NAME $OOONANA_REPO_URI"
      if [ -f "$OOONANA_REPO_URI/$id.pkg" ]; then
        LOADED_PKG_FILE="$OOONANA_REPO_URI/$id.pkg"
        LOADED_REPO_DIR="$OOONANA_REPO_URI"
        LOADED_REPO_NAME="$OOONANA_REPO_NAME"
        LOADED_REPO_KEY="$OOONANA_REPO_KEY"
        return 0
      fi
    fi
  done
  return 1
}

load_pkg() {
  id="$1"
  reset_pkg_vars
  find_pkg_file "$id" || die "unknown package: $id"
  verify_loaded_pkg_file
  . "$LOADED_PKG_FILE"
  [ "$OOONANA_PKG_ID" = "$id" ] || die "bad package metadata: $id"
  [ -n "$OOONANA_PKG_VERSION" ] || die "package missing version: $id"
  [ -n "$OOONANA_PKG_SUMMARY" ] || die "package missing summary: $id"
}

load_installed_pkg() {
  id="$1"
  reset_pkg_vars
  LOADED_PKG_FILE="$INSTALLED_DIR/$id.pkg"
  [ -f "$LOADED_PKG_FILE" ] || die "package not installed: $id"
  LOADED_REPO_DIR="$INSTALLED_DIR"
  LOADED_REPO_NAME="installed"
  LOADED_REPO_KEY=""
  . "$LOADED_PKG_FILE"
  [ "$OOONANA_PKG_ID" = "$id" ] || die "bad installed package metadata: $id"
  [ -n "$OOONANA_PKG_VERSION" ] || die "installed package missing version: $id"
  [ -n "$OOONANA_PKG_SUMMARY" ] || die "installed package missing summary: $id"
}

installed_pkg_version() {
  id="$1"
  load_installed_pkg "$id"
  printf '%s\n' "$OOONANA_PKG_VERSION"
}

sha256_file() {
  path="$1"
  have sha256sum || die "missing command: sha256sum"
  sha256sum "$path" | awk '{print $1}'
}

repo_checksum_expected() {
  sums_file="$1"
  rel_path="$2"
  awk -v rel="$rel_path" '$2 == rel { print $1; found = 1; exit } END { if (!found) exit 1 }' "$sums_file"
}

repo_signature_key() {
  repo_path="$1"
  repo_key="${2:-}"
  if [ -n "$repo_key" ]; then
    printf '%s\n' "$repo_key"
    return 0
  fi
  if [ -n "${OOONANA_REPO_VERIFY_KEY:-}" ]; then
    printf '%s\n' "$OOONANA_REPO_VERIFY_KEY"
    return 0
  fi
  if [ -f "$repo_path/repo.pub" ] && [ "${OOONANA_TRUST_REPO_EMBEDDED_KEY:-0}" = "1" ]; then
    printf '%s\n' "$repo_path/repo.pub"
    return 0
  fi
  return 1
}

verify_repo_signature() {
  repo_path="$1"
  repo_key="${2:-}"
  sums_file="$repo_path/SHA256SUMS"
  sig_file="$repo_path/SHA256SUMS.sig"
  if [ ! -f "$sums_file" ]; then
    [ "${OOONANA_REQUIRE_SIGNED_REPOS:-0}" = "1" ] && die "repo signature missing: $repo_path"
    return 0
  fi
  if [ ! -f "$sig_file" ]; then
    [ "${OOONANA_REQUIRE_SIGNED_REPOS:-0}" = "1" ] && die "repo signature missing: $repo_path"
    return 0
  fi
  have openssl || die "signed repo needs openssl: $repo_path"
  key_file="$(repo_signature_key "$repo_path" "$repo_key" || true)"
  [ -n "$key_file" ] || die "signed repo missing trusted key: $repo_path"
  [ -f "$key_file" ] || die "trusted repo key missing: $key_file"
  openssl dgst -sha256 -verify "$key_file" -signature "$sig_file" "$sums_file" >/dev/null 2>&1 ||
    die "repo signature mismatch: $repo_path"
}

verify_repo_checksum() {
  repo_path="$1"
  rel_path="$2"
  repo_key="${3:-}"
  sums_file="$repo_path/SHA256SUMS"
  [ -f "$sums_file" ] || return 0
  verify_repo_signature "$repo_path" "$repo_key"
  target="$repo_path/$rel_path"
  [ -f "$target" ] || die "missing repo file: $rel_path"
  expected="$(repo_checksum_expected "$sums_file" "$rel_path" || true)"
  [ -n "$expected" ] || die "missing checksum: $rel_path"
  actual="$(sha256_file "$target")"
  [ "$actual" = "$expected" ] || die "sha256 mismatch: $rel_path"
}

verify_loaded_pkg_file() {
  [ -n "${LOADED_REPO_DIR:-}" ] || return 0
  [ -n "${LOADED_PKG_FILE:-}" ] || return 0
  rel_path="$(basename "$LOADED_PKG_FILE")"
  verify_repo_checksum "$LOADED_REPO_DIR" "$rel_path" "${LOADED_REPO_KEY:-}"
}

verify_loaded_archive_file() {
  [ -n "${LOADED_REPO_DIR:-}" ] || return 0
  [ -n "${OOONANA_PKG_ARCHIVE:-}" ] || return 0
  case "$OOONANA_PKG_ARCHIVE" in
    /*) return 0 ;;
    *) verify_repo_checksum "$LOADED_REPO_DIR" "$OOONANA_PKG_ARCHIVE" "${LOADED_REPO_KEY:-}" ;;
  esac
}

sign_repo_index() {
  repo_path="$1"
  sign_key="$2"
  [ -n "$sign_key" ] || return 0
  [ -f "$sign_key" ] || die "sign key missing: $sign_key"
  have openssl || die "repo signing needs openssl"
  openssl dgst -sha256 -sign "$sign_key" -out "$repo_path/SHA256SUMS.sig" "$repo_path/SHA256SUMS"
}

write_repo_index_entry() {
  repo_path="$1"
  file="$2"
  index_tmp="$3"
  sums_tmp="$4"
  rel_pkg="$(basename "$file")"
  reset_pkg_vars
  . "$file"
  [ -n "$OOONANA_PKG_ID" ] || die "bad package metadata: $file"
  [ -n "$OOONANA_PKG_VERSION" ] || die "package missing version: $file"
  [ -n "$OOONANA_PKG_SUMMARY" ] || die "package missing summary: $file"
  case "$OOONANA_PKG_ID" in
    *[!A-Za-z0-9_.+-]*|"") die "bad package id: $OOONANA_PKG_ID" ;;
  esac
  pkg_sha="$(sha256_file "$file")"
  archive_rel=""
  if [ -n "$OOONANA_PKG_ARCHIVE" ]; then
    case "$OOONANA_PKG_ARCHIVE" in
      /*|../*|*/../*|..)
        die "repo archive must be relative and safe: $OOONANA_PKG_ID"
        ;;
    esac
    archive_rel="$OOONANA_PKG_ARCHIVE"
    archive_path="$repo_path/$archive_rel"
    [ -f "$archive_path" ] || die "missing archive: $archive_rel"
    archive_sha="$(sha256_file "$archive_path")"
    if [ -n "$OOONANA_PKG_SHA256" ] && [ "$archive_sha" != "$OOONANA_PKG_SHA256" ]; then
      die "archive sha256 mismatch: $OOONANA_PKG_ID"
    fi
    printf '%s  %s\n' "$archive_sha" "$archive_rel" >> "$sums_tmp"
  fi
  deps_field="$OOONANA_PKG_DEPS"
  archive_field="$archive_rel"
  [ -n "$deps_field" ] || deps_field="-"
  [ -n "$archive_field" ] || archive_field="-"
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$OOONANA_PKG_ID" "$OOONANA_PKG_VERSION" "${OOONANA_PKG_KIND:-bundle}" "$OOONANA_PKG_SUMMARY" "$deps_field" "$archive_field" "$pkg_sha" >> "$index_tmp"
  printf '%s  %s\n' "$pkg_sha" "$rel_pkg" >> "$sums_tmp"
}

cmd_repo_index() {
  repo_path="$REPO_DIR"
  sign_key="${OOONANA_REPO_SIGN_KEY:-}"
  seen_repo_path=0
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --sign-key)
        [ "$#" -ge 2 ] || die "usage: ooonana repo index [--sign-key KEY] [PATH]"
        sign_key="$2"
        shift 2
        ;;
      --sign-key=*)
        sign_key="${1#--sign-key=}"
        shift
        ;;
      -*)
        die "usage: ooonana repo index [--sign-key KEY] [PATH]"
        ;;
      *)
        [ "$seen_repo_path" -eq 0 ] || die "usage: ooonana repo index [--sign-key KEY] [PATH]"
        repo_path="$1"
        seen_repo_path=1
        shift
        ;;
    esac
  done
  [ -d "$repo_path" ] || die "missing repo: $repo_path"
  index_tmp="$repo_path/index.tsv.tmp"
  sums_tmp="$repo_path/SHA256SUMS.tmp"
  : > "$index_tmp"
  : > "$sums_tmp"
  count=0
  for file in "$repo_path"/*.pkg; do
    [ -f "$file" ] || continue
    write_repo_index_entry "$repo_path" "$file" "$index_tmp" "$sums_tmp"
    count=$((count + 1))
  done
  sort -u "$index_tmp" -o "$index_tmp"
  sort -u "$sums_tmp" -o "$sums_tmp"
  mv "$index_tmp" "$repo_path/index.tsv"
  mv "$sums_tmp" "$repo_path/SHA256SUMS"
  sign_repo_index "$repo_path" "$sign_key"
  printf 'indexed %s package(s): %s\n' "$count" "$repo_path"
  [ -n "$sign_key" ] && printf 'signed repo: %s\n' "$repo_path/SHA256SUMS.sig"
  return 0
}

safe_repo_name() {
  case "$1" in
    *[!A-Za-z0-9_.-]*|"") return 1 ;;
    *) return 0 ;;
  esac
}

safe_repo_uri() {
  case "$1" in
    http://*|https://*|file://*|/*) return 0 ;;
    *) return 1 ;;
  esac
}

safe_repo_key() {
  case "$1" in
    ""|/*) return 0 ;;
    *) return 1 ;;
  esac
}

repo_source_path() {
  printf '%s/%s.repo\n' "$SOURCES_DIR" "$1"
}

cmd_repo_add() {
  name="${1:-}"
  uri="${2:-}"
  key="${3:-}"
  [ "$#" -ge 2 ] && [ "$#" -le 3 ] || die "usage: ooonana repo add NAME URI [PUBKEY]"
  safe_repo_name "$name" || die "bad repo name: $name"
  safe_repo_uri "$uri" || die "bad repo URI: $uri"
  safe_repo_key "$key" || die "repo key path must be absolute: $key"
  [ -z "$key" ] || [ -f "$key" ] || die "repo key missing: $key"
  mkdir -p "$SOURCES_DIR"
  path="$(repo_source_path "$name")"
  {
    printf 'OOONANA_REPO_NAME="%s"\n' "$name"
    printf 'OOONANA_REPO_URI="%s"\n' "$uri"
    [ -z "$key" ] || printf 'OOONANA_REPO_KEY="%s"\n' "$key"
  } > "$path"
  printf 'repo added %s %s\n' "$name" "$uri"
  [ -z "$key" ] || printf 'repo key %s\n' "$key"
}

cmd_repo_remove() {
  name="${1:-}"
  [ "$#" -eq 1 ] || die "usage: ooonana repo remove NAME"
  safe_repo_name "$name" || die "bad repo name: $name"
  path="$(repo_source_path "$name")"
  [ -f "$path" ] || die "repo not found: $name"
  rm -f "$path"
  printf 'repo removed %s\n' "$name"
}

cmd_repo_doctor_one() {
  repo_name="$1"
  repo_path="$2"
  repo_key="${3:-}"
  if repo_is_tarball "$repo_path"; then
    if repo_is_remote "$repo_path" || [ -f "$repo_path" ]; then
      printf '%s: ok %s\n' "$repo_name" "$repo_path"
      return 0
    fi
    printf '%s: missing %s\n' "$repo_name" "$repo_path" >&2
    return 1
  fi
  if repo_is_remote "$repo_path"; then
    printf '%s: ok remote %s\n' "$repo_name" "$repo_path"
    return 0
  fi
  if [ ! -d "$repo_path" ]; then
    printf '%s: missing %s\n' "$repo_name" "$repo_path" >&2
    return 1
  fi
  if [ -f "$repo_path/index.tsv" ]; then
    verify_repo_signature "$repo_path" "$repo_key"
    printf '%s: ok %s\n' "$repo_name" "$repo_path"
    return 0
  fi
  for file in "$repo_path"/*.pkg; do
    if [ -f "$file" ]; then
      printf '%s: ok %s\n' "$repo_name" "$repo_path"
      return 0
    fi
  done
  printf '%s: missing package index %s\n' "$repo_name" "$repo_path" >&2
  return 1
}

cmd_repo_doctor() {
  ensure_pkg_dirs
  sources_tmp="$CACHE_DIR/repo-doctor.tsv.$$"
  repo_sources > "$sources_tmp"
  status=0
  while IFS='	' read -r repo_name repo_path repo_key; do
    [ -n "$repo_name" ] || continue
    cmd_repo_doctor_one "$repo_name" "$repo_path" "${repo_key:-}" || status=1
  done < "$sources_tmp"
  rm -f "$sources_tmp"
  if [ "$status" -eq 0 ]; then
    printf 'OOONANA_REPO_DOCTOR_OK\n'
  fi
  return "$status"
}

pkg_ids() {
  [ -d "$REPO_DIR" ] || die "missing repo: $REPO_DIR"
  {
    for file in "$REPO_DIR"/*.pkg; do
      [ -f "$file" ] || continue
      basename "$file" .pkg
    done
    if [ -d "$SOURCES_DIR" ]; then
      for source_file in "$SOURCES_DIR"/*.repo; do
        [ -f "$source_file" ] || continue
        load_repo_source_file "$source_file"
        if repo_is_tarball "$OOONANA_REPO_URI"; then
          repo_path="$(tarball_repo_cached_dir "$OOONANA_REPO_NAME" "$OOONANA_REPO_URI")"
          if [ -f "$repo_path/index.tsv" ]; then
            awk 'BEGIN { FS = "\t" } NF { print $1 }' "$repo_path/index.tsv"
          fi
        elif repo_is_remote "$OOONANA_REPO_URI"; then
          repo_path="$(remote_repo_cached_dir "$OOONANA_REPO_NAME" "$OOONANA_REPO_URI")"
          if [ -f "$repo_path/index.tsv" ]; then
            awk 'BEGIN { FS = "\t" } NF { print $1 }' "$repo_path/index.tsv"
          fi
        else
          [ -d "$OOONANA_REPO_URI" ] || die "missing repo source: $OOONANA_REPO_NAME $OOONANA_REPO_URI"
          for file in "$OOONANA_REPO_URI"/*.pkg; do
            [ -f "$file" ] || continue
            basename "$file" .pkg
          done
        fi
      done
    fi
  } | sort -u
}

pkg_installed() {
  [ -f "$INSTALLED_DIR/$1.pkg" ]
}

safe_pkg_id() {
  case "$1" in
    *[!A-Za-z0-9_.+-]*|"") return 1 ;;
    *) return 0 ;;
  esac
}

pkg_hook() {
  printf '%s/hooks/%s.%s\n' "${LOADED_REPO_DIR:-$REPO_DIR}" "$1" "$2"
}

run_pkg_hook() {
  id="$1"
  action="$2"
  hook="$(pkg_hook "$id" "$action")"
  [ -e "$hook" ] || return 0
  [ -x "$hook" ] || die "hook not executable: $hook"
  printf 'running %s hook %s\n' "$action" "$id"
  export OOONANA_ROOT
  export OOONANA_REPO_DIR="$REPO_DIR"
  export OOONANA_STATE_DIR="$STATE_DIR"
  export OOONANA_CACHE_DIR="$CACHE_DIR"
  export OOONANA_PKG_ID OOONANA_PKG_VERSION OOONANA_PKG_KIND OOONANA_PKG_SUMMARY
  "$hook"
}

pkg_archive_path() {
  archive="$1"
  case "$archive" in
    /*) printf '%s\n' "$archive" ;;
    *) printf '%s/%s\n' "${LOADED_REPO_DIR:-$REPO_DIR}" "$archive" ;;
  esac
}

pkg_files_dir() {
  printf '%s/files\n' "$STATE_DIR"
}

pkg_files_manifest() {
  printf '%s/%s.list\n' "$(pkg_files_dir)" "$1"
}

verify_pkg_archive() {
  id="$1"
  archive_path="$2"
  [ -f "$archive_path" ] || die "missing archive: $OOONANA_PKG_ARCHIVE"
  if [ -n "$OOONANA_PKG_SHA256" ]; then
    have sha256sum || die "missing command: sha256sum"
    actual="$(sha256sum "$archive_path" | awk '{print $1}')"
    [ "$actual" = "$OOONANA_PKG_SHA256" ] || die "sha256 mismatch: $id"
  fi
}

tar_list_archive() {
  archive_path="$1"
  if tar --quoting-style=literal -tzf "$archive_path" >/dev/null 2>&1; then
    tar --quoting-style=literal -tzf "$archive_path"
  else
    tar -tzf "$archive_path"
  fi
}

validate_archive_entries() {
  id="$1"
  archive_path="$2"
  have tar || die "missing command: tar"
  tar_list_archive "$archive_path" | while IFS= read -r entry; do
    clean_entry="${entry#./}"
    [ -n "$clean_entry" ] || continue
    case "$clean_entry" in
      /*|../*|*/../*|..)
        die "unsafe archive path in $id: $entry"
        ;;
    esac
  done
}

safe_manifest_entry() {
  case "$1" in
    ""|.|..|/*|../*|*/../*|*/..)
      return 1
      ;;
    *)
      return 0
      ;;
  esac
}

install_pkg_archive() {
  id="$1"
  if [ -n "${LOADED_REPO_URI:-}" ]; then
    case "$OOONANA_PKG_ARCHIVE" in
      /*) ;;
      *) remote_repo_cache_file "$LOADED_REPO_NAME" "$LOADED_REPO_URI" "$OOONANA_PKG_ARCHIVE" >/dev/null ;;
    esac
  fi
  archive_path="$(pkg_archive_path "$OOONANA_PKG_ARCHIVE")"
  verify_loaded_archive_file
  verify_pkg_archive "$id" "$archive_path"
  validate_archive_entries "$id" "$archive_path"
  mkdir -p "$OOONANA_ROOT"
  tar -xzf "$archive_path" -C "$OOONANA_ROOT"
  mkdir -p "$(pkg_files_dir)"
  tar_list_archive "$archive_path" | sed -e 's#^\./##' -e '/^$/d' > "$(pkg_files_manifest "$id")"
  printf 'unpacked %s\n' "$OOONANA_PKG_ARCHIVE"
}

remove_pkg_archive_files() {
  id="$1"
  manifest="$(pkg_files_manifest "$id")"
  [ -f "$manifest" ] || return 0

  sed '1!G;h;$!d' "$manifest" | while IFS= read -r entry; do
    [ -n "$entry" ] || continue
    safe_manifest_entry "$entry" || die "unsafe manifest path in $id: $entry"
    target="$(root_join "/$entry")"
    if [ -d "$target" ] && [ ! -L "$target" ]; then
      rmdir "$target" 2>/dev/null || true
    else
      rm -f "$target"
    fi
  done
  rm -f "$manifest"
  printf 'removed archive files %s\n' "$id"
}

pkg_state() {
  if pkg_installed "$1"; then
    printf 'installed'
  else
    printf 'available'
  fi
}

print_pkg_line() {
  id="$1"
  state="$2"
  printf '%-14s %-8s %-10s %s\n' "$id" "$OOONANA_PKG_VERSION" "$state" "$OOONANA_PKG_SUMMARY"
}

cmd_version() {
  printf 'ooonana %s\n' "$VERSION"
}

cmd_doctor() {
  printf 'kernel: %s\n' "$(uname -r)"
  if have apt-get; then
    printf 'apt: ok\n'
  else
    printf 'apt: missing\n'
  fi
  if have systemctl; then
    printf 'systemd: present\n'
  else
    printf 'systemd: missing\n'
  fi
}

cmd_me() {
  logo_file="$(root_join /usr/share/ooonana/logo.txt)"
  if [ -f "$logo_file" ]; then
    cat "$logo_file"
    return 0
  fi
  cat <<'LOGO'
Ooonana OS
      __________________
     |    __      __    |
     |   /  \    /  \   |
   / |                  |\
  /  |     \______/     | \
     |__________________|
          |        |
LOGO
}

is_wsl() {
  [ -n "${WSL_DISTRO_NAME:-}" ] && return 0
  [ -n "${WSL_INTEROP:-}" ] && return 0
  grep -qi microsoft /proc/sys/kernel/osrelease 2>/dev/null && return 0
  grep -qi wsl /proc/sys/kernel/osrelease 2>/dev/null && return 0
  grep -qi microsoft /proc/version 2>/dev/null && return 0
  grep -qi wsl /proc/version 2>/dev/null && return 0
  return 1
}

cmd_wsl() {
  subcmd="${1:-doctor}"
  case "$subcmd" in
    doctor|status)
      if is_wsl; then
        printf 'wsl: yes\n'
      else
        printf 'wsl: no\n'
      fi
      printf 'distro: %s\n' "${WSL_DISTRO_NAME:-unknown}"
      printf 'build_dir: %s\n' "${OOONANA_BUILD_DIR:-/var/tmp/ooonana-os/build}"
      if have qemu-system-x86_64; then
        printf 'qemu: ok\n'
      else
        printf 'qemu: missing\n'
      fi
      if have wslpath; then
        printf 'wslpath: ok\n'
      else
        printf 'wslpath: missing\n'
      fi
      ;;
    *) die "usage: ooonana wsl [doctor|status]" ;;
  esac
}

cmd_setup() {
  setup_bin="${SCRIPT_DIR}/ooonana-setup"
  if [ ! -x "$setup_bin" ]; then
    setup_bin="$(root_join /usr/bin/ooonana-setup)"
  fi
  [ -x "$setup_bin" ] || die "missing setup command: $setup_bin"
  exec "$setup_bin" "$@"
}

cmd_update() {
  ensure_pkg_dirs
  tmp="$CACHE_DIR/index.tsv.tmp"
  sources_tmp="$CACHE_DIR/sources.tsv.tmp"
  repo_count=0
  : > "$tmp"
  repo_sources > "$sources_tmp"
  while IFS='	' read -r repo_name repo_path repo_key; do
    [ -n "$repo_name" ] || continue
    repo_count=$((repo_count + 1))
    repo_remote=0
    if repo_is_tarball "$repo_path"; then
      repo_path="$(sync_tarball_repo "$repo_name" "$repo_path")"
    elif repo_is_remote "$repo_path"; then
      repo_remote=1
      repo_path="$(sync_remote_repo "$repo_name" "$repo_path")"
    fi
    [ -d "$repo_path" ] || die "missing repo source: $repo_name $repo_path"
    verify_repo_signature "$repo_path" "${repo_key:-}"
    if [ -f "$repo_path/index.tsv" ]; then
      while IFS='	' read -r pkg_id pkg_version pkg_kind pkg_summary pkg_deps pkg_archive pkg_sha; do
        [ -n "$pkg_id" ] || continue
        [ -n "$pkg_version" ] || die "repo index missing version: $repo_path"
        [ -n "$pkg_summary" ] || die "repo index missing summary: $repo_path"
        [ "$pkg_deps" = "-" ] && pkg_deps=""
        [ "$pkg_archive" = "-" ] && pkg_archive=""
        if [ "$repo_remote" -eq 0 ]; then
          verify_repo_checksum "$repo_path" "$pkg_id.pkg" "${repo_key:-}"
          [ -z "$pkg_archive" ] || verify_repo_checksum "$repo_path" "$pkg_archive" "${repo_key:-}"
        fi
        printf '%s\t%s\t%s\t%s\t%s\n' "$repo_name" "$pkg_id" "$pkg_version" "${pkg_kind:-bundle}" "$pkg_summary" >> "$tmp"
      done < "$repo_path/index.tsv"
    else
      for file in "$repo_path"/*.pkg; do
        [ -f "$file" ] || continue
        reset_pkg_vars
        . "$file"
        [ -n "$OOONANA_PKG_ID" ] || die "bad package metadata: $file"
        [ -n "$OOONANA_PKG_VERSION" ] || die "package missing version: $file"
        [ -n "$OOONANA_PKG_SUMMARY" ] || die "package missing summary: $file"
        printf '%s\t%s\t%s\t%s\t%s\n' "$repo_name" "$OOONANA_PKG_ID" "$OOONANA_PKG_VERSION" "${OOONANA_PKG_KIND:-bundle}" "$OOONANA_PKG_SUMMARY" >> "$tmp"
      done
    fi
  done < "$sources_tmp"
  mv "$sources_tmp" "$CACHE_DIR/sources.tsv"
  mv "$tmp" "$CACHE_DIR/index.tsv"
  count="$(wc -l < "$CACHE_DIR/index.tsv" | tr -d ' ')"
  printf 'ooonana repo: synced %s package(s) from %s source(s)\n' "$count" "$repo_count"
  if [ "${OOONANA_APT_UPDATE:-0}" = "1" ] && have apt-get; then
    apt-get update
  fi
}

cmd_sources() {
  repo_sources | while IFS='	' read -r repo_name repo_path repo_key; do
    [ -n "$repo_name" ] || continue
    if [ -n "${repo_key:-}" ]; then
      printf '%-12s %s key=%s\n' "$repo_name" "$repo_path" "$repo_key"
    else
      printf '%-12s %s\n' "$repo_name" "$repo_path"
    fi
  done
}

cmd_clean() {
  dry_run=0
  apt_clean=0
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --dry-run) dry_run=1 ;;
      --apt) apt_clean=1 ;;
      *) die "usage: ooonana clean [--dry-run] [--apt]" ;;
    esac
    shift
  done

  case "$CACHE_DIR" in
    ""|"/"|"/.") die "unsafe cache dir: $CACHE_DIR" ;;
  esac

  if [ "$dry_run" -eq 1 ]; then
    printf 'would clean ooonana cache %s\n' "$CACHE_DIR"
  else
    rm -rf "$CACHE_DIR/repos" "$CACHE_DIR/index.tsv" "$CACHE_DIR/sources.tsv"
    mkdir -p "$CACHE_DIR"
    printf 'ooonana cache cleaned: %s\n' "$CACHE_DIR"
  fi

  if [ "$apt_clean" -eq 1 ]; then
    have sudo || die "sudo missing"
    if [ "$dry_run" -eq 1 ]; then
      printf 'would run sudo apt-get autoremove -y\n'
      printf 'would run sudo apt-get clean\n'
    else
      sudo apt-get autoremove -y
      sudo apt-get clean
    fi
  fi
}

cmd_list() {
  installed_only=0
  upgradeable_only=0
  case "${1:-}" in
    --installed) installed_only=1; shift ;;
    --upgradeable) upgradeable_only=1; shift ;;
    ""|--all) ;;
    *) die "usage: ooonana list [--installed|--upgradeable]" ;;
  esac

  if [ "$installed_only" -eq 1 ]; then
    [ -d "$INSTALLED_DIR" ] || return 0
    for file in "$INSTALLED_DIR"/*.pkg; do
      [ -f "$file" ] || return 0
      id="$(basename "$file" .pkg)"
      load_installed_pkg "$id"
      print_pkg_line "$id" "installed"
    done | sort
    return 0
  fi

  if [ "$upgradeable_only" -eq 1 ]; then
    [ -d "$INSTALLED_DIR" ] || return 0
    for file in "$INSTALLED_DIR"/*.pkg; do
      [ -f "$file" ] || return 0
      id="$(basename "$file" .pkg)"
      old_version="$(installed_pkg_version "$id")"
      load_pkg "$id"
      if [ "$old_version" != "$OOONANA_PKG_VERSION" ]; then
        printf '%s %s -> %s %s\n' "$id" "$old_version" "$OOONANA_PKG_VERSION" "$OOONANA_PKG_SUMMARY"
      fi
    done | sort
    return 0
  fi

  pkg_ids | while IFS= read -r id; do
    [ -n "$id" ] || continue
    load_pkg "$id"
    print_pkg_line "$id" "$(pkg_state "$id")"
  done
}

cmd_info() {
  id="${1:-}"
  [ -n "$id" ] || die "usage: ooonana info PACKAGE"
  load_pkg "$id"
  printf 'id: %s\n' "$OOONANA_PKG_ID"
  printf 'version: %s\n' "$OOONANA_PKG_VERSION"
  printf 'kind: %s\n' "${OOONANA_PKG_KIND:-bundle}"
  printf 'source: %s\n' "$LOADED_REPO_NAME"
  printf 'state: %s\n' "$(pkg_state "$id")"
  printf 'summary: %s\n' "$OOONANA_PKG_SUMMARY"
  [ -n "$OOONANA_PKG_DEPS" ] && printf 'deps: %s\n' "$OOONANA_PKG_DEPS"
  [ -n "$OOONANA_PKG_CONFLICTS" ] && printf 'conflicts: %s\n' "$OOONANA_PKG_CONFLICTS"
  [ -n "$OOONANA_PKG_ARCHIVE" ] && printf 'archive: %s\n' "$OOONANA_PKG_ARCHIVE"
  [ -n "$OOONANA_PKG_COMPONENTS" ] && printf 'components: %s\n' "$OOONANA_PKG_COMPONENTS"
  [ -n "$OOONANA_PKG_NOTES" ] && printf 'notes: %s\n' "$OOONANA_PKG_NOTES"
  return 0
}

cmd_search() {
  query="$*"
  [ -n "$query" ] || die "usage: ooonana search QUERY"
  query_lc="$(printf '%s' "$query" | tr '[:upper:]' '[:lower:]')"
  pkg_ids | while IFS= read -r id; do
    [ -n "$id" ] || continue
    load_pkg "$id"
    haystack="$(printf '%s %s %s %s %s' "$OOONANA_PKG_ID" "$OOONANA_PKG_SUMMARY" "$OOONANA_PKG_KIND" "$OOONANA_PKG_COMPONENTS" "$OOONANA_PKG_NOTES" | tr '[:upper:]' '[:lower:]')"
    case "$haystack" in
      *"$query_lc"*) print_pkg_line "$id" "$(pkg_state "$id")" ;;
    esac
  done
}

cmd_depends() {
  id="${1:-}"
  [ -n "$id" ] || die "usage: ooonana depends PACKAGE"
  safe_pkg_id "$id" || die "bad package id: $id"
  shift || true
  [ "$#" -eq 0 ] || die "usage: ooonana depends PACKAGE"
  load_pkg "$id"
  if [ -z "$OOONANA_PKG_DEPS" ]; then
    printf '%s has no dependencies\n' "$id"
    return 0
  fi
  for dep in $OOONANA_PKG_DEPS; do
    printf '%s depends: %s\n' "$id" "$dep"
  done
}

cmd_files() {
  id="${1:-}"
  [ -n "$id" ] || die "usage: ooonana files PACKAGE"
  safe_pkg_id "$id" || die "bad package id: $id"
  shift || true
  [ "$#" -eq 0 ] || die "usage: ooonana files PACKAGE"
  pkg_installed "$id" || die "package not installed: $id"
  manifest="$(pkg_files_manifest "$id")"
  if [ ! -f "$manifest" ]; then
    printf 'no file manifest %s\n' "$id"
    return 0
  fi
  while IFS= read -r entry; do
    [ -n "$entry" ] || continue
    printf '/%s\n' "${entry#/}"
  done < "$manifest"
}

verify_pkg_files() {
  id="$1"
  pkg_installed "$id" || die "package not installed: $id"
  manifest="$(pkg_files_manifest "$id")"
  missing=0
  if [ -f "$manifest" ]; then
    while IFS= read -r entry; do
      [ -n "$entry" ] || continue
      target="$(root_join "/$entry")"
      if [ ! -e "$target" ]; then
        printf 'missing /%s\n' "${entry#/}" >&2
        missing=1
      fi
    done < "$manifest"
  fi
  [ "$missing" -eq 0 ]
}

cmd_verify() {
  id="${1:-}"
  [ -n "$id" ] || die "usage: ooonana verify PACKAGE"
  safe_pkg_id "$id" || die "bad package id: $id"
  shift || true
  [ "$#" -eq 0 ] || die "usage: ooonana verify PACKAGE"
  verify_pkg_files "$id" || exit 1
  printf 'verify ok %s\n' "$id"
}

cmd_check() {
  packages=""
  while [ "$#" -gt 0 ]; do
    case "$1" in
      -*) die "usage: ooonana check [PACKAGE...]" ;;
      *) packages="$packages ${1}" ;;
    esac
    shift
  done

  if [ -z "$packages" ]; then
    if [ ! -d "$INSTALLED_DIR" ]; then
      printf 'check ok: no packages installed\n'
      return 0
    fi
    for file in "$INSTALLED_DIR"/*.pkg; do
      [ -f "$file" ] || continue
      packages="$packages $(basename "$file" .pkg)"
    done
  fi
  if [ -z "$packages" ]; then
    printf 'check ok: no packages installed\n'
    return 0
  fi

  for id in $packages; do
    safe_pkg_id "$id" || die "bad package id: $id"
    verify_pkg_files "$id" || exit 1
    printf 'check ok %s\n' "$id"
  done
}

check_pkg_conflicts() {
  id="$1"
  for conflict in $OOONANA_PKG_CONFLICTS; do
    [ "$conflict" = "$id" ] && die "$id conflicts with itself"
    if pkg_installed "$conflict"; then
      die "$id conflicts with installed package: $conflict"
    fi
  done
}

installed_dependent_of() {
  target="$1"
  [ -d "$INSTALLED_DIR" ] || return 0
  for file in "$INSTALLED_DIR"/*.pkg; do
    [ -f "$file" ] || continue
    dep_id="$(basename "$file" .pkg)"
    [ "$dep_id" = "$target" ] && continue
    reset_pkg_vars
    . "$file"
    for dep in $OOONANA_PKG_DEPS; do
      if [ "$dep" = "$target" ]; then
        printf '%s\n' "$dep_id"
        return 0
      fi
    done
  done
  return 0
}

check_reverse_dependencies() {
  id="$1"
  force="$2"
  planned="${3:-}"
  [ "$force" -eq 1 ] && return 0
  installed_dependent_of "$id" | while IFS= read -r dependent; do
    [ -n "$dependent" ] || continue
    case " $planned " in
      *" $dependent "*) continue ;;
      *) die "$id required by installed package: $dependent" ;;
    esac
  done
}

install_one_pkg() {
  local id dry_run deps conflicts dep old_installing
  id="$1"
  dry_run="$2"
  safe_pkg_id "$id" || die "bad package id: $id"
  case " ${OOONANA_INSTALLING:-} " in
    *" $id "*)
      load_pkg "$id"
      if [ "$OOONANA_PKG_KIND" = "apk" ]; then
        printf 'dependency cycle tolerated: %s\n' "$id"
        return 0
      fi
      die "dependency cycle:${OOONANA_INSTALLING:-} $id"
      ;;
  esac
  if pkg_installed "$id"; then
    printf 'already installed %s\n' "$id"
    return 0
  fi
  load_pkg "$id"
  check_pkg_conflicts "$id"

  deps="$OOONANA_PKG_DEPS"
  conflicts="$OOONANA_PKG_CONFLICTS"
  old_installing="${OOONANA_INSTALLING:-}"
  OOONANA_INSTALLING="$old_installing $id"
  for dep in $deps; do
    install_one_pkg "$dep" "$dry_run"
  done
  OOONANA_INSTALLING="$old_installing"
  load_pkg "$id"
  OOONANA_PKG_DEPS="$deps"
  OOONANA_PKG_CONFLICTS="$conflicts"

  if pkg_installed "$id"; then
    printf 'already installed %s\n' "$id"
    return 0
  fi
  if [ "$dry_run" -eq 1 ]; then
    printf 'would install %s %s\n' "$id" "$OOONANA_PKG_VERSION"
    [ -n "$OOONANA_PKG_ARCHIVE" ] && printf 'would unpack %s\n' "$OOONANA_PKG_ARCHIVE"
    [ -e "$(pkg_hook "$id" install)" ] && printf 'would run install hook %s\n' "$id"
    return 0
  fi

  ensure_pkg_dirs
  [ -n "$OOONANA_PKG_ARCHIVE" ] && install_pkg_archive "$id"
  run_pkg_hook "$id" install
  cp "$LOADED_PKG_FILE" "$INSTALLED_DIR/$id.pkg"
  printf 'installed %s %s\n' "$id" "$OOONANA_PKG_VERSION"
}

cmd_get() {
  dry_run=0
  packages=""
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --dry-run) dry_run=1 ;;
      *) packages="$packages ${1}" ;;
    esac
    shift
  done
  [ -n "$packages" ] || die "usage: ooonana get PACKAGE [--dry-run]"

  for id in $packages; do
    safe_pkg_id "$id" || die "bad package id: $id"
    install_one_pkg "$id" "$dry_run"
  done
}

upgrade_one_pkg() {
  local id dry_run old_version new_version deps dep archive_path old_upgrading
  id="$1"
  dry_run="$2"
  safe_pkg_id "$id" || die "bad package id: $id"
  case " ${OOONANA_UPGRADING:-} " in
    *" $id "*)
      load_pkg "$id"
      if [ "$OOONANA_PKG_KIND" = "apk" ]; then
        printf 'upgrade dependency cycle tolerated: %s\n' "$id"
        return 0
      fi
      die "upgrade dependency cycle:${OOONANA_UPGRADING:-} $id"
      ;;
  esac
  pkg_installed "$id" || die "package not installed: $id"

  old_version="$(installed_pkg_version "$id")"
  load_pkg "$id"
  new_version="$OOONANA_PKG_VERSION"
  if [ "$old_version" = "$new_version" ]; then
    printf 'already current %s %s\n' "$id" "$new_version"
    return 0
  fi
  if [ "$dry_run" -eq 0 ] && [ -n "$OOONANA_PKG_ARCHIVE" ]; then
    archive_path="$(pkg_archive_path "$OOONANA_PKG_ARCHIVE")"
    verify_pkg_archive "$id" "$archive_path"
    validate_archive_entries "$id" "$archive_path"
  fi

  deps="$OOONANA_PKG_DEPS"
  old_upgrading="${OOONANA_UPGRADING:-}"
  OOONANA_UPGRADING="$old_upgrading $id"
  for dep in $deps; do
    if pkg_installed "$dep"; then
      upgrade_one_pkg "$dep" "$dry_run"
    else
      install_one_pkg "$dep" "$dry_run"
    fi
  done
  OOONANA_UPGRADING="$old_upgrading"
  load_pkg "$id"

  if [ "$dry_run" -eq 1 ]; then
    printf 'would upgrade %s %s -> %s\n' "$id" "$old_version" "$new_version"
    [ -n "$OOONANA_PKG_ARCHIVE" ] && printf 'would unpack %s\n' "$OOONANA_PKG_ARCHIVE"
    [ -e "$(pkg_hook "$id" install)" ] && printf 'would run install hook %s\n' "$id"
    return 0
  fi

  ensure_pkg_dirs
  remove_pkg_archive_files "$id"
  [ -n "$OOONANA_PKG_ARCHIVE" ] && install_pkg_archive "$id"
  run_pkg_hook "$id" install
  cp "$LOADED_PKG_FILE" "$INSTALLED_DIR/$id.pkg"
  printf 'upgraded %s %s -> %s\n' "$id" "$old_version" "$new_version"
}

cmd_upgrade() {
  dry_run=0
  packages=""
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --dry-run) dry_run=1 ;;
      *) packages="$packages ${1}" ;;
    esac
    shift
  done

  if [ -z "$packages" ]; then
    [ -d "$INSTALLED_DIR" ] || { printf 'no packages installed\n'; return 0; }
    for file in "$INSTALLED_DIR"/*.pkg; do
      [ -f "$file" ] || { printf 'no packages installed\n'; return 0; }
      id="$(basename "$file" .pkg)"
      old_version="$(installed_pkg_version "$id")"
      load_pkg "$id"
      if [ "$old_version" != "$OOONANA_PKG_VERSION" ]; then
        packages="$packages $id"
      fi
    done
  fi

  if [ -z "$packages" ]; then
    printf 'no upgrades\n'
    return 0
  fi

  for id in $packages; do
    safe_pkg_id "$id" || die "bad package id: $id"
    upgrade_one_pkg "$id" "$dry_run"
  done
}

purge_pkg_config() {
  id="$1"
  rm -rf "$(root_join "/etc/ooonana/packages/$id")" "$(root_join "/var/lib/ooonana/packages/config/$id")"
  printf 'purged config %s\n' "$id"
}

remove_one_pkg() {
  id="$1"
  dry_run="$2"
  purge="$3"
  force="$4"
  planned="${5:-}"
  safe_pkg_id "$id" || die "bad package id: $id"
  if ! pkg_installed "$id"; then
    printf 'not installed %s\n' "$id"
    return 0
  fi
  check_reverse_dependencies "$id" "$force" "$planned"
  if find_pkg_file "$id"; then
    load_pkg "$id"
  else
    load_installed_pkg "$id"
  fi
  if [ "$dry_run" -eq 1 ]; then
    if [ "$purge" -eq 1 ]; then
      printf 'would purge %s\n' "$id"
      printf 'would purge config %s\n' "$id"
    else
      printf 'would remove %s\n' "$id"
    fi
    [ -f "$(pkg_files_manifest "$id")" ] && printf 'would remove archive files %s\n' "$id"
    [ -e "$(pkg_hook "$id" remove)" ] && printf 'would run remove hook %s\n' "$id"
    return 0
  fi
  run_pkg_hook "$id" remove
  remove_pkg_archive_files "$id"
  rm -f "$INSTALLED_DIR/$id.pkg"
  if [ "$purge" -eq 1 ]; then
    purge_pkg_config "$id"
    printf 'purged %s\n' "$id"
  else
    printf 'removed %s\n' "$id"
  fi
}

cmd_remove() {
  dry_run=0
  force=0
  packages=""
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --dry-run) dry_run=1 ;;
      --force) force=1 ;;
      *) packages="$packages ${1}" ;;
    esac
    shift
  done
  [ -n "$packages" ] || die "usage: ooonana remove PACKAGE... [--dry-run] [--force]"
  for id in $packages; do
    safe_pkg_id "$id" || die "bad package id: $id"
  done
  for id in $packages; do
    remove_one_pkg "$id" "$dry_run" 0 "$force" "$packages"
  done
}

cmd_purge() {
  dry_run=0
  force=0
  packages=""
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --dry-run) dry_run=1 ;;
      --force) force=1 ;;
      *) packages="$packages ${1}" ;;
    esac
    shift
  done
  [ -n "$packages" ] || die "usage: ooonana purge PACKAGE... [--dry-run] [--force]"
  for id in $packages; do
    safe_pkg_id "$id" || die "bad package id: $id"
  done
  for id in $packages; do
    remove_one_pkg "$id" "$dry_run" 1 "$force" "$packages"
  done
}

fix_one_pkg() {
  id="$1"
  dry_run="$2"
  reinstall="$3"
  safe_pkg_id "$id" || die "bad package id: $id"
  if ! pkg_installed "$id"; then
    if [ "$dry_run" -eq 1 ]; then
      printf 'would install missing %s\n' "$id"
    else
      install_one_pkg "$id" 0
      printf 'fixed missing %s\n' "$id"
    fi
    return 0
  fi

  broken=0
  if [ "$reinstall" -eq 1 ]; then
    broken=1
  elif ! verify_pkg_files "$id"; then
    broken=1
  fi

  if [ "$broken" -eq 0 ]; then
    printf 'fix ok %s\n' "$id"
    return 0
  fi

  if [ "$dry_run" -eq 1 ]; then
    printf 'would reinstall %s\n' "$id"
    return 0
  fi

  load_pkg "$id"
  remove_pkg_archive_files "$id"
  rm -f "$INSTALLED_DIR/$id.pkg"
  install_one_pkg "$id" 0
  printf 'fixed %s\n' "$id"
}

cmd_fix() {
  dry_run=0
  reinstall=0
  packages=""
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --dry-run) dry_run=1 ;;
      --reinstall) reinstall=1 ;;
      *) packages="$packages ${1}" ;;
    esac
    shift
  done

  ensure_pkg_dirs
  if [ "$dry_run" -eq 1 ]; then
    printf 'would update repos\n'
  else
    cmd_update
  fi

  if [ -z "$packages" ]; then
    for file in "$INSTALLED_DIR"/*.pkg; do
      [ -f "$file" ] || continue
      packages="$packages $(basename "$file" .pkg)"
    done
  fi
  if [ -z "$packages" ]; then
    printf 'fix ok: no packages installed\n'
    return 0
  fi
  for id in $packages; do
    safe_pkg_id "$id" || die "bad package id: $id"
    fix_one_pkg "$id" "$dry_run" "$reinstall"
  done
}

cmd_repo() {
  subcmd="${1:-}"
  case "$subcmd" in
    add)
      shift
      cmd_repo_add "$@"
      ;;
    remove|rm)
      shift
      cmd_repo_remove "$@"
      ;;
    doctor|check)
      shift
      [ "$#" -eq 0 ] || die "usage: ooonana repo doctor"
      cmd_repo_doctor
      ;;
    index)
      shift
      cmd_repo_index "$@"
      ;;
    build)
      shift
      cmd_repo_build "$@"
      ;;
    *) die "usage: ooonana repo [add|remove|doctor|index|build]" ;;
  esac
}

find_repo_build_script() {
  if [ -n "${OOONANA_SOURCE_ROOT:-}" ] && [ -x "$OOONANA_SOURCE_ROOT/scripts/build-package-repo.sh" ]; then
    printf '%s\n' "$OOONANA_SOURCE_ROOT/scripts/build-package-repo.sh"
    return 0
  fi
  repo_root="$(CDPATH= cd "$SCRIPT_DIR/../../../.." 2>/dev/null && pwd || true)"
  if [ -n "$repo_root" ] && [ -x "$repo_root/scripts/build-package-repo.sh" ]; then
    printf '%s\n' "$repo_root/scripts/build-package-repo.sh"
    return 0
  fi
  if [ -x /usr/share/ooonana/scripts/build-package-repo.sh ]; then
    printf '%s\n' /usr/share/ooonana/scripts/build-package-repo.sh
    return 0
  fi
  return 1
}

cmd_repo_build() {
  script="$(find_repo_build_script || true)"
  [ -n "$script" ] || die "repo build needs Ooonana source checkout: set OOONANA_SOURCE_ROOT"
  if have bash; then
    exec bash "$script" "$@"
  fi
  die "repo build needs bash"
}

cmd_ai_setup() {
  mkdir -p "$(dirname "$AI_CONFIG")"
  if [ ! -f "$AI_CONFIG" ]; then
    umask 077
    cat > "$AI_CONFIG" <<'EOF'
# Ooonana AI uses NVIDIA NIM or Google Gemini.
# Get a key from https://build.nvidia.com/settings/api-keys
# Get a Gemini key from https://aistudio.google.com/app/apikey
OOONANA_AI_PROVIDER=nim
NVIDIA_API_KEY=
GEMINI_API_KEY=
OOONANA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
OOONANA_NIM_MODEL=nvidia/nemotron-3-super-120b-a12b
OOONANA_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
OOONANA_GEMINI_MODEL=gemini-2.5-flash
OOONANA_MODEL_CODE=qwen/qwen3-coder-480b-a35b-instruct
OOONANA_MODEL_FAST=qwen/qwen3-next-80b-a3b-instruct
OOONANA_MODEL_DEEP=nvidia/nemotron-3-super-120b-a12b
EOF
  fi
  chmod 600 "$AI_CONFIG"
  printf 'AI config: %s\n' "$AI_CONFIG"
}

cmd_ai_doctor() {
  if [ ! -s "$AI_CONFIG" ]; then
    printf 'AI config missing: run ooonana ai setup\n'
    exit 1
  fi
  . "$AI_CONFIG"
  provider="${AI_PROVIDER_OVERRIDE:-${OOONANA_AI_PROVIDER:-nim}}"
  if { [ "$provider" = "gemini" ] || [ "$provider" = "auto" ]; } && { [ -n "${GEMINI_API_KEY:-}" ] || [ -n "${GOOGLE_API_KEY:-}" ]; }; then
    printf 'AI config: ok\n'
  elif [ -n "${NVIDIA_API_KEY:-}" ] || [ -n "${NVIDIA_NIM_API_KEY:-}" ] || [ -n "${OPENAI_API_KEY:-}" ]; then
    printf 'AI config: ok\n'
  elif [ "$provider" = "gemini" ]; then
    printf 'AI config missing GEMINI_API_KEY or GOOGLE_API_KEY\n'
    exit 1
  else
    printf 'AI config missing NVIDIA_API_KEY\n'
    exit 1
  fi
}

cmd_ai_code() {
  [ "$#" -gt 0 ] || { printf 'prompt required\n' >&2; exit 1; }
  cmd_ai_doctor >/dev/null
  printf 'AI code request queued: %s\n' "$*"
}

cmd_ai_config_load() {
  [ -f "$AI_CONFIG" ] && . "$AI_CONFIG"
  return 0
}

cmd_ai_provider_key_present() {
  provider="$1"
  if [ "$provider" = "gemini" ]; then
    [ -n "${GEMINI_API_KEY:-}" ] || [ -n "${GOOGLE_API_KEY:-}" ]
  else
    [ -n "${NVIDIA_API_KEY:-}" ] || [ -n "${NVIDIA_NIM_API_KEY:-}" ] || [ -n "${OPENAI_API_KEY:-}" ]
  fi
}

cmd_ai_provider_model() {
  provider="$1"
  if [ "$provider" = "gemini" ]; then
    printf '%s\n' "${OOONANA_GEMINI_MODEL:-gemini-2.5-flash}"
  else
    printf '%s\n' "${OOONANA_NIM_MODEL:-nvidia/nemotron-3-super-120b-a12b}"
  fi
}

cmd_ai_provider_label() {
  case "$1" in
    gemini) printf 'Google Gemini\n' ;;
    *) printf 'NVIDIA NIM\n' ;;
  esac
}

cmd_ai_env_set() {
  key="$1"
  value="$2"
  mkdir -p "$(dirname "$AI_CONFIG")"
  [ -f "$AI_CONFIG" ] || cmd_ai_setup >/dev/null
  tmp="$AI_CONFIG.tmp.$$"
  found=0
  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in
      "$key="*) printf '%s=%s\n' "$key" "$value"; found=1 ;;
      *) printf '%s\n' "$line" ;;
    esac
  done < "$AI_CONFIG" > "$tmp"
  if [ "$found" -eq 0 ]; then
    printf '%s=%s\n' "$key" "$value" >> "$tmp"
  fi
  mv "$tmp" "$AI_CONFIG"
  chmod 600 "$AI_CONFIG"
}

cmd_ai_provider() {
  subcmd="${1:-show}"
  case "$subcmd" in
    ""|show)
      cmd_ai_config_load
      provider="${AI_PROVIDER_OVERRIDE:-${OOONANA_AI_PROVIDER:-nim}}"
      [ "$provider" = "auto" ] && provider="nim"
      key_state="missing"
      cmd_ai_provider_key_present "$provider" && key_state="present"
      printf 'active: %s\n' "$provider"
      printf 'provider: %s\n' "$(cmd_ai_provider_label "$provider")"
      printf 'model: %s\n' "$(cmd_ai_provider_model "$provider")"
      printf 'key: %s\n' "$key_state"
      ;;
    set)
      value="${2:-}"
      [ "$value" = "nim" ] || [ "$value" = "gemini" ] || die "usage: ooonana ai provider [show|set nim|set gemini]"
      cmd_ai_env_set OOONANA_AI_PROVIDER "$value"
      printf 'provider: %s\n' "$value"
      printf 'config: %s\n' "$AI_CONFIG"
      ;;
    *) die "usage: ooonana ai provider [show|set nim|set gemini]" ;;
  esac
}

cmd_ai_tools() {
  cat <<'TOOLS'
Ooonana CLI tool registry
system     show kernel, host, cwd, and storage basics
processes  list running processes
packages   list Ooonana packages
files      list files under a path
desktop    show display, i3, xterm, and opener hints
activity   show recent local activity hints
shell      guarded shell command, blocks unless --yes
TOOLS
}

cmd_ai_desktop() {
  printf '[desktop]\n'
  printf 'display: %s\n' "${DISPLAY:-missing}"
  printf 'wayland: %s\n' "${WAYLAND_DISPLAY:-missing}"
  printf 'desktop_session: %s\n' "${XDG_CURRENT_DESKTOP:-${DESKTOP_SESSION:-unknown}}"
  for cmd in i3 i3-msg xterm xsetroot feh xdg-open grim import; do
    if have "$cmd"; then
      printf '%s: present\n' "$cmd"
    else
      printf '%s: missing\n' "$cmd"
    fi
  done
  if have i3-msg; then
    sample="$(i3-msg -t get_tree 2>/dev/null | head -c 1200 || true)"
    if [ -n "$sample" ]; then
      printf '\n[i3 tree sample]\n%s\n' "$sample"
    fi
  fi
}

cmd_ai_status() {
  cmd_ai_config_load
  provider="${AI_PROVIDER_OVERRIDE:-${OOONANA_AI_PROVIDER:-nim}}"
  [ "$provider" = "auto" ] && provider="nim"
  key_state="missing"
  cmd_ai_provider_key_present "$provider" && key_state="present"
  printf 'Ooonana AI status\n'
  printf 'provider: %s\n' "$(cmd_ai_provider_label "$provider")"
  printf 'model: %s\n' "$(cmd_ai_provider_model "$provider")"
  printf 'key: %s\n' "$key_state"
  printf 'config: %s\n' "$AI_CONFIG"
  printf 'python: missing\n'
}

cmd_ai_models() {
  cat <<'MODELS'
nim default: nvidia/nemotron-3-super-120b-a12b
code: qwen/qwen3-coder-480b-a35b-instruct
fast: qwen/qwen3-next-80b-a3b-instruct
gemini default: gemini-2.5-flash
deep: gemini-2.5-pro
MODELS
}

cmd_ai_config_print() {
  [ -f "$AI_CONFIG" ] || die "AI config missing: run ooonana ai setup"
  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in
      NVIDIA_API_KEY=*|NVIDIA_NIM_API_KEY=*|OPENAI_API_KEY=*|GEMINI_API_KEY=*|GOOGLE_API_KEY=*)
        printf '%s=...redacted\n' "${line%%=*}"
        ;;
      *) printf '%s\n' "$line" ;;
    esac
  done < "$AI_CONFIG"
}

cmd_ai_env() {
  printf 'kernel: %s\n' "$(uname -r)"
  printf 'host: %s\n' "$(hostname 2>/dev/null || printf unknown)"
  printf 'cwd: %s\n' "$(pwd)"
  df -h / 2>/dev/null | sed -n '1,2p' || true
}

cmd_ai_agents() {
  printf 'system\nactivity\nsummarizer\ntools\n'
}

cmd_ai_agent() {
  case "${1:-}" in
    activity)
      printf 'recent shell history: unavailable in shell fallback\n'
      printf 'recent Ooonana AI history: unavailable in shell fallback\n'
      ;;
    ""|list) cmd_ai_agents ;;
    *) die "usage: ooonana ai agent activity" ;;
  esac
}

cmd_ai_tool() {
  tool="${1:-}"
  shift || true
  case "$tool" in
    system) cmd_ai_env ;;
    processes) ps ;;
    packages) cmd_list ;;
    files) ls -la "${1:-.}" ;;
    desktop) cmd_ai_desktop ;;
    activity) cmd_ai_agent activity ;;
    shell)
      if [ "${1:-}" != "--yes" ]; then
        printf 'blocked: add --yes\n'
        return 0
      fi
      shift
      [ "$#" -gt 0 ] || die "usage: ooonana ai tool shell --yes COMMAND..."
      "$@"
      ;;
    ""|list) cmd_ai_tools ;;
    *) die "usage: ooonana ai tool NAME [ARGS...]" ;;
  esac
}

cmd_ai_tasks() {
  printf 'tasks: python required for persistent task state\n'
}

cmd_ai_audit() {
  printf 'audit: python required for persistent audit log\n'
}

cmd_ai() {
  if have python3 && [ -f "$AI_APP" ]; then
    exec python3 "$AI_APP" --config "$AI_CONFIG" "$@"
  fi

  AI_PROVIDER_OVERRIDE=""
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --config)
        [ "$#" -ge 2 ] || die "ooonana ai --config requires a path"
        AI_CONFIG="$2"
        shift 2
        ;;
      --config=*)
        AI_CONFIG="${1#--config=}"
        shift
        ;;
      --state-dir)
        [ "$#" -ge 2 ] || die "ooonana ai --state-dir requires a path"
        OOONANA_AI_STATE_DIR="$2"
        shift 2
        ;;
      --state-dir=*)
        OOONANA_AI_STATE_DIR="${1#--state-dir=}"
        shift
        ;;
      --provider)
        [ "$#" -ge 2 ] || die "ooonana ai --provider requires nim, gemini, or auto"
        AI_PROVIDER_OVERRIDE="$2"
        shift 2
        ;;
      --provider=*)
        AI_PROVIDER_OVERRIDE="${1#--provider=}"
        shift
        ;;
      *) break ;;
    esac
  done

  case "${1:-}" in
    setup) shift; cmd_ai_setup "$@" ;;
    doctor) shift; cmd_ai_doctor "$@" ;;
    config) shift; cmd_ai_config_print "$@" ;;
    env) shift; cmd_ai_env "$@" ;;
    models|model) shift; cmd_ai_models "$@" ;;
    provider) shift; cmd_ai_provider "$@" ;;
    agents) shift; cmd_ai_agents "$@" ;;
    agent) shift; cmd_ai_agent "$@" ;;
    tools) shift; cmd_ai_tools "$@" ;;
    tool) shift; cmd_ai_tool "$@" ;;
    status) shift; cmd_ai_status "$@" ;;
    audit) shift; cmd_ai_audit "$@" ;;
    tasks|task) shift; cmd_ai_tasks "$@" ;;
    history|sessions)
      history_cmd="$1"
      shift
      printf '%s: python required for session history\n' "$history_cmd"
      ;;
    code|ask)
      shift
      cmd_ai_code "$@"
      ;;
    ""|chat|ping)
      die "python3 required for ooonana ai"
      ;;
    *) usage; exit 1 ;;
  esac
}

main() {
  cmd="${1:-}"
  [ -n "$cmd" ] || { usage; exit 0; }
  shift || true

  case "$cmd" in
    version|--version|-v) cmd_version ;;
    me) cmd_me ;;
    doctor) cmd_doctor ;;
    wsl) cmd_wsl "$@" ;;
    setup) cmd_setup "$@" ;;
    update) cmd_update ;;
    sources) cmd_sources ;;
    list) cmd_list "$@" ;;
    search) cmd_search "$@" ;;
    info) cmd_info "$@" ;;
    show) cmd_info "$@" ;;
    depends) cmd_depends "$@" ;;
    files) cmd_files "$@" ;;
    verify) cmd_verify "$@" ;;
    check) cmd_check "$@" ;;
    get|install|add) cmd_get "$@" ;;
    upgrade) cmd_upgrade "$@" ;;
    remove|uninstall) cmd_remove "$@" ;;
    purge) cmd_purge "$@" ;;
    fix) cmd_fix "$@" ;;
    repo) cmd_repo "$@" ;;
    clean) cmd_clean "$@" ;;
    ai)
      cmd_ai "$@"
      ;;
    help|--help|-h) cmd_help "$@" ;;
    *) usage; exit 1 ;;
  esac
}

main "$@"
