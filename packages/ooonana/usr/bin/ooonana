#!/bin/sh
set -eu

VERSION="0.8.0"
HOME_DIR="${HOME:-/root}"
if [ -n "${OOONANA_AI_CONFIG:-}" ]; then
  AI_CONFIG="$OOONANA_AI_CONFIG"
elif [ -n "${XDG_CONFIG_HOME:-}" ]; then
  AI_CONFIG="$XDG_CONFIG_HOME/ooonana/ai.env"
else
  AI_CONFIG="$HOME_DIR/.config/ooonana/ai.env"
fi
OOONANA_ROOT="${OOONANA_ROOT:-/}"

root_join() {
  path="$1"
  if [ "$OOONANA_ROOT" = "/" ]; then
    printf '%s\n' "$path"
  else
    printf '%s/%s\n' "${OOONANA_ROOT%/}" "${path#/}"
  fi
}

script_dir() {
  path="$0"
  while [ -L "$path" ] && command -v readlink >/dev/null 2>&1; do
    dir="$(CDPATH= cd -- "$(dirname -- "$path")" && pwd)"
    target="$(readlink "$path")" || break
    case "$target" in
      /*) path="$target" ;;
      *) path="$dir/$target" ;;
    esac
  done
  CDPATH= cd -- "$(dirname -- "$path")" && pwd
}

SCRIPT_DIR="$(script_dir)"
LOCAL_AI_APP="${SCRIPT_DIR%/bin}/lib/ooonana/ai/ooonana_ai.py"
AI_APP="${OOONANA_AI_APP:-$LOCAL_AI_APP}"
if [ ! -f "$AI_APP" ]; then
  AI_APP="$(root_join /usr/lib/ooonana/ai/ooonana_ai.py)"
fi

REPO_DIR="${OOONANA_REPO_DIR:-$(root_join /usr/lib/ooonana/repo)}"
SOURCES_DIR="${OOONANA_SOURCES_DIR:-$(root_join /etc/ooonana/sources.d)}"
STATE_DIR="${OOONANA_STATE_DIR:-$(root_join /var/lib/ooonana/packages)}"
CACHE_DIR="${OOONANA_CACHE_DIR:-$(root_join /var/cache/ooonana)}"
INSTALLED_DIR="$STATE_DIR/installed"

usage_main() {
  cat <<'USAGE'
Ooonana command center.

Usage:
  ooonana version
  ooonana me
  ooonana doctor
  ooonana wsl [doctor|status]
  ooonana setup [options]

Small shell tools:
  bunana                 Exit shell when loaded by Ooonana login shell
  bunana --shutdown      Power off
  bunana --restart       Reboot
  clear                  Clear terminal
  oonana                 Play Ooonana brick game
  neofetch               Show Ooonana logo and system info

Packages:
  ooonana update
  ooonana sources
  ooonana list [--installed|--upgradeable]
  ooonana search QUERY
  ooonana info PACKAGE
  ooonana show PACKAGE
  ooonana depends PACKAGE
  ooonana files PACKAGE
  ooonana verify PACKAGE
  ooonana check [PACKAGE...]
  ooonana get PACKAGE [--dry-run]
  ooonana install PACKAGE [--dry-run]
  ooonana add PACKAGE [--dry-run]
  ooonana upgrade [PACKAGE...] [--dry-run]
  ooonana remove PACKAGE... [--dry-run]
  ooonana uninstall PACKAGE... [--dry-run]
  ooonana purge PACKAGE... [--dry-run]
  ooonana fix [PACKAGE...] [--dry-run] [--reinstall]
